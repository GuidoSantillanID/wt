# ─── wt sync — detailed merge tests (isolated project) ───────────────────────

SYNC_PROJ="${TMPROOT}/sync-detail-proj"
mkdir -p "$SYNC_PROJ"
git -C "$SYNC_PROJ" init -q -b main
git -C "$SYNC_PROJ" config user.email "test@test.com"
git -C "$SYNC_PROJ" config user.name "Test"
echo "init" > "$SYNC_PROJ/README.md"
git -C "$SYNC_PROJ" add README.md
git -C "$SYNC_PROJ" commit -q -m "initial"
git -C "$SYNC_PROJ" checkout -q -b dev
echo "dev-content" > "$SYNC_PROJ/dev.txt"
git -C "$SYNC_PROJ" add dev.txt
git -C "$SYNC_PROJ" commit -q -m "dev commit"
git -C "$SYNC_PROJ" checkout -q main

section "wt sync — conflict detected, files listed"
cd "$SYNC_PROJ"
git -C "$SYNC_PROJ" checkout -q dev
# Add multi-line data.txt to dev for auto-merge test
printf "line1\nline2\nline3\n" > "${SYNC_PROJ}/data.txt"
git -C "$SYNC_PROJ" add data.txt
git -C "$SYNC_PROJ" commit -q -m "add data.txt"
SYNC_WT_CONFLICT="${SYNC_PROJ}/.worktrees/sync-conflict"
wt new "sync conflict" 2>/dev/null
# Worktree: change README.md (conflict) + append to data.txt (auto-merge)
echo "worktree-change" > "${SYNC_WT_CONFLICT}/README.md"
printf "line1\nline2\nline3\nwt-appended\n" > "${SYNC_WT_CONFLICT}/data.txt"
git -C "$SYNC_WT_CONFLICT" add README.md data.txt
git -C "$SYNC_WT_CONFLICT" commit -q -m "wt changed readme"
# Base: change README.md (conflict) + prepend to data.txt (auto-merge)
git -C "$SYNC_PROJ" checkout -q dev
echo "base-change" > "${SYNC_PROJ}/README.md"
printf "base-prepended\nline1\nline2\nline3\n" > "${SYNC_PROJ}/data.txt"
git -C "$SYNC_PROJ" add README.md data.txt
git -C "$SYNC_PROJ" commit -q -m "base changed readme"
git -C "$SYNC_PROJ" checkout -q main
cd "$SYNC_WT_CONFLICT"
out_conflict=$(wt sync 2>&1 || true)
assert_contains "reports conflict" "conflict" "$out_conflict"
assert_contains "lists conflicted file" "README.md" "$out_conflict"
assert_contains "shows conflict line number" "README.md:1" "$out_conflict"
assert_contains "shows conflict count" "1 conflict" "$out_conflict"
assert_contains "shows auto-merged summary" "Auto-merged:" "$out_conflict"
assert_contains "lists auto-merged file" "data.txt" "$out_conflict"
assert_contains "shows HEAD commit subject" "wt changed readme" "$out_conflict"
assert_contains "shows base commit subject" "base changed readme" "$out_conflict"
assert_contains "shows merge continue instruction" "git merge --continue" "$out_conflict"
git -C "$SYNC_WT_CONFLICT" merge --abort 2>/dev/null || true
cd "$SYNC_PROJ"
git -C "$SYNC_PROJ" worktree remove "$SYNC_WT_CONFLICT" --force 2>/dev/null || true
git -C "$SYNC_PROJ" branch -D "wt/sync-conflict" 2>/dev/null || true
git -C "$SYNC_PROJ" checkout -q main

section "wt sync — errors when base branch not found locally"
cd "$SYNC_PROJ"
git -C "$SYNC_PROJ" checkout -q -b temp-base
echo "temp" > "${SYNC_PROJ}/temp.txt"
git -C "$SYNC_PROJ" add temp.txt
git -C "$SYNC_PROJ" commit -q -m "temp base commit"
SYNC_WT_NOREF="${SYNC_PROJ}/.worktrees/sync-noref"
wt new "sync noref" 2>/dev/null
git -C "$SYNC_PROJ" checkout -q main
git -C "$SYNC_PROJ" branch -D temp-base
cd "$SYNC_WT_NOREF"
out_noref=$(wt sync 2>&1 || true)
assert_contains "errors on missing local base branch" "not found locally" "$out_noref"
cd "$SYNC_PROJ"
git -C "$SYNC_PROJ" worktree remove "$SYNC_WT_NOREF" --force 2>/dev/null || true
git -C "$SYNC_PROJ" branch -D "wt/sync-noref" 2>/dev/null || true

section "wt sync — blocks when merge already in progress"
cd "$SYNC_PROJ"
git -C "$SYNC_PROJ" checkout -q dev
SYNC_WT_INPROG="${SYNC_PROJ}/.worktrees/sync-inprog"
wt new "sync inprog" 2>/dev/null
echo "wt-readme" > "${SYNC_WT_INPROG}/README.md"
git -C "$SYNC_WT_INPROG" add README.md
git -C "$SYNC_WT_INPROG" commit -q -m "wt readme"
git -C "$SYNC_PROJ" checkout -q dev
echo "dev-readme" > "${SYNC_PROJ}/README.md"
