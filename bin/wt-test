section "wt pr — shows base branch and retarget hint"
cd "$REPO"
git -C "$REPO" checkout -q dev
BARE_HINT="${TMPROOT}/bare-hint.git"
git -C "$REPO" clone --bare . "$BARE_HINT" 2>/dev/null
WT_PATH_HINT="${REPO}/.worktrees/pr-hint-test"
