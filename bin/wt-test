#!/usr/bin/env bash
# =============================================================================
# wt-test — Integration test suite for the `wt` worktree tool
# =============================================================================
# Usage: wt-test [--keep]
#   --keep    Preserve the temp dir on failure (for debugging)
#
# Creates a real git repo in /tmp, runs all commands against it, cleans up.
# Run with stdin closed to prevent interactive prompts from blocking:
#   bash bin/wt-test < /dev/null
# =============================================================================

set -euo pipefail

WT="${WT_BIN:-$(dirname "$(cd "$(dirname "$0")" && pwd)")/bin/wt}"
# If run as bin/wt-test, resolve relative to the script's directory
if [[ ! -f "$WT" ]]; then
  WT="$(cd "$(dirname "$0")" && pwd)/wt"
fi
KEEP=0
[[ "${1:-}" == "--keep" ]] && KEEP=1

# ─── Colors ──────────────────────────────────────────────────────────────────

if [[ -t 1 ]]; then
  RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[0;33m'
  CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'
else
  RED=''; GREEN=''; YELLOW=''; CYAN=''; BOLD=''; RESET=''
fi

# ─── Test framework ──────────────────────────────────────────────────────────

PASS=0; FAIL=0

pass() { echo -e "  ${GREEN}✓${RESET} $*"; PASS=$(( PASS + 1 )); }
fail() { echo -e "  ${RED}✗${RESET} $*"; FAIL=$(( FAIL + 1 )); }
section() { echo -e "\n${BOLD}${CYAN}▸ $*${RESET}"; }

assert_eq() {
  local desc="$1" expected="$2" actual="$3"
  if [[ "$actual" == "$expected" ]]; then pass "$desc"
  else
    fail "$desc"
    echo -e "    expected: ${YELLOW}${expected}${RESET}"
    echo -e "    actual:   ${RED}${actual}${RESET}"
  fi
}

assert_contains() {
  local desc="$1" needle="$2" haystack="$3"
  if [[ "$haystack" == *"$needle"* ]]; then pass "$desc"
  else
    fail "$desc"
    echo -e "    expected to contain: ${YELLOW}${needle}${RESET}"
    echo -e "    actual: ${RED}${haystack}${RESET}"
  fi
}

assert_not_contains() {
  local desc="$1" needle="$2" haystack="$3"
  if [[ "$haystack" != *"$needle"* ]]; then pass "$desc"
  else
    fail "$desc"
    echo -e "    expected NOT to contain: ${YELLOW}${needle}${RESET}"
    echo -e "    actual: ${RED}${haystack}${RESET}"
  fi
}

assert_file_exists()     { [[ -f "$2" ]] && pass "$1" || fail "$1 (missing: $2)"; }
assert_dir_exists()      { [[ -d "$2" ]] && pass "$1" || fail "$1 (missing: $2)"; }
assert_dir_not_exists()  { [[ ! -d "$2" ]] && pass "$1" || fail "$1 (still exists: $2)"; }

# Run wt with WT_REGISTRY pointing at our test registry file
wt() { WT_REGISTRY="$registry_file" bash "$WT" "$@"; }

# ─── Setup ───────────────────────────────────────────────────────────────────

TMPROOT=$(mktemp -d /tmp/wt-test-XXXXXX)
# Resolve symlinks (macOS /tmp → /private/tmp) so path comparisons work
TMPROOT=$(cd "$TMPROOT" && pwd -P)

# test_base: directory holding our test project
test_base="${TMPROOT}/projects"
mkdir -p "$test_base"

# registry_file: isolated registry for all test invocations
registry_file="${TMPROOT}/wt-registry"

# Create test git repo inside test_base
REPO="${test_base}/test-project"
mkdir -p "$REPO"
git -C "$REPO" init -q -b main
git -C "$REPO" config user.email "test@test.com"
git -C "$REPO" config user.name "Test"
echo "hello" > "$REPO/README.md"
git -C "$REPO" add README.md
git -C "$REPO" commit -q -m "initial commit"
git -C "$REPO" checkout -q -b dev
echo "dev" > "$REPO/dev.txt"
git -C "$REPO" add dev.txt
git -C "$REPO" commit -q -m "dev commit"

cleanup() {
  if (( FAIL > 0 )) && (( KEEP == 1 )); then
    echo -e "\n${YELLOW}--keep: temp dir preserved at ${TMPROOT}${RESET}"
  else
    rm -rf "$TMPROOT"
  fi
}
trap cleanup EXIT

echo -e "${BOLD}wt test suite${RESET}"
echo -e "Repo:   ${CYAN}${REPO}${RESET}"
echo -e "Binary: ${CYAN}${WT}${RESET}"

# ─── Tests ───────────────────────────────────────────────────────────────────

section "wt help"
out=$(wt help 2>&1)
assert_contains "USAGE"    "USAGE"    "$out"
assert_contains "wt new"   "wt new"   "$out"
assert_contains     "wt finish"      "wt finish"  "$out"
assert_contains     "wt abandon"     "wt abandon" "$out"
assert_not_contains "wt drop absent" "wt drop"    "$out"
assert_contains     "wt list"        "wt list"    "$out"

section "wt done — unknown command"
done_out=$(wt done 2>&1 || true)
assert_contains     "wt done is unknown" "Unknown command" "$done_out"

section "wt drop — unknown command"
drop_out=$(wt drop 2>&1 || true)
assert_contains     "wt drop is unknown" "Unknown command" "$drop_out"

# ── wt list — empty registry (no wt new yet) ────────────────────────────────
section "wt list — no crash with missing registry file"
# Simulate fresh install: registry file does not exist yet
_empty_reg=$(mktemp -u)  # generate a path but don't create the file
list_empty=$(WT_REGISTRY="$_empty_reg" bash "$WT" list 2>&1)
assert_contains     "shows 'no worktrees' when registry absent" "No active worktrees" "$list_empty"
assert_not_contains "no unbound variable error"                 "unbound variable"    "$list_empty"

# ── wt new ──────────────────────────────────────────────────────────────────
section "wt new — basic creation"

cd "$REPO"
WT_PATH="${REPO}/.worktrees/fix-the-sidebar-overflow-bug"

stdout=$(wt new "fix the sidebar overflow bug" 2>/dev/null)

assert_dir_exists  "worktree dir created"     "$WT_PATH"
assert_file_exists ".wt-meta written"         "${WT_PATH}/.wt-meta"
assert_eq          "stdout is worktree path"  "$WT_PATH" "$stdout"

section "wt new — .wt-meta contents"
meta="${WT_PATH}/.wt-meta"
assert_contains "base_branch=dev"                         "base_branch=dev"                        "$(cat "$meta")"
assert_contains "slug recorded"                           "slug=fix-the-sidebar-overflow-bug"      "$(cat "$meta")"
assert_contains "branch recorded"                         "branch=wt/fix-the-sidebar-overflow-bug" "$(cat "$meta")"
assert_contains "description recorded"                    "description=fix the sidebar overflow bug" "$(cat "$meta")"
assert_not_contains "no shell quoting in meta"            "\\'"                                    "$(cat "$meta")"

section "wt new — single quotes in description"
cd "$REPO"
stdout2=$(wt new "it's a tricky description" 2>/dev/null)
WT_PATH2="${REPO}/.worktrees/its-a-tricky-description"
meta2="${WT_PATH2}/.wt-meta"
assert_dir_exists  "worktree dir created"                        "$WT_PATH2"
assert_eq          "stdout is worktree path"                     "$WT_PATH2" "$stdout2"
assert_contains    "slug strips apostrophe"                      "slug=its-a-tricky-description"     "$(cat "$meta2")"
assert_contains    "description preserved with apostrophe"       "description=it's a tricky description" "$(cat "$meta2")"

# ── .wt-meta not counted in dirty ───────────────────────────────────────────
section "git status — .wt-meta excluded from dirty count"

common_dir=$(git -C "$WT_PATH" rev-parse --git-common-dir 2>/dev/null)
assert_file_exists ".git/info/exclude exists"       "${common_dir}/info/exclude"
assert_contains    ".wt-meta in exclude"            ".wt-meta"     "$(cat "${common_dir}/info/exclude")"
assert_contains    ".worktrees/ in exclude"         ".worktrees/"  "$(cat "${common_dir}/info/exclude")"
assert_not_contains ".worktrees/ not in .gitignore" ".worktrees/"  "$(cat "${REPO}/.gitignore" 2>/dev/null)"

dirty=$(git -C "$WT_PATH" status --porcelain 2>/dev/null)
assert_eq "worktree status is clean" "" "$dirty"

# ── wt list ─────────────────────────────────────────────────────────────────
section "wt list — output"
list_out=$(wt list 2>/dev/null)
assert_contains    "shows branch"                "wt/fix-the-sidebar-overflow-bug" "$list_out"
assert_contains    "shows clean"                 "clean"                           "$list_out"
assert_not_contains "no dirty count shown"       "dirty"                           "$list_out"
assert_contains    "shows description"           "fix the sidebar overflow bug"    "$list_out"

section "wt list — age display is valid"
# human_age() must produce something like "0m ago", "1h ago", etc.
age_out=$(wt list 2>/dev/null)
if [[ "$age_out" =~ [0-9]+[mhdw]\ ago ]]; then pass "age string matches [0-9]+[mhdw] ago"
else fail "age string invalid or missing (got: $age_out)"; fi

section "wt list — no ANSI codes when piped"
piped=$(wt list 2>/dev/null | cat)
assert_not_contains "no ESC codes" $'\033[' "$piped"

# ── wt new conflicts ────────────────────────────────────────────────────────
section "wt new — conflicts"
cd "$REPO"
out=$(wt new "fix the sidebar overflow bug" 2>&1 || true)
assert_contains "error on duplicate" "already exists" "$out"

# ── wt new from inside a worktree ────────────────────────────────────────────
section "wt new — from inside an existing worktree"
cd "$WT_PATH"
stdout3=$(wt new "new from inside worktree" 2>/dev/null)
expected3="${REPO}/.worktrees/new-from-inside-worktree"
assert_eq          "creates in main checkout, not nested" "$expected3" "$stdout3"
assert_dir_exists  "worktree exists at correct path"      "$expected3"
assert_dir_not_exists "not nested inside current worktree" "${WT_PATH}/.worktrees/new-from-inside-worktree"

# ── wt new — two-arg form removed ────────────────────────────────────────────
section "wt new — two-arg form errors"
cd "$TMPROOT"
out=$(wt new test-project "task via project name" 2>&1 || true)
assert_contains "two-arg form errors" "Usage:" "$out"

# ── wt finish — safety checks ────────────────────────────────────────────────
section "wt finish — dirty check"
cd "$WT_PATH"
# Modify a tracked file so git status --porcelain shows modified (not just untracked)
echo "dirty" >> README.md
out=$(wt finish 2>&1 || true)
assert_contains "blocks on uncommitted changes" "Uncommitted changes" "$out"
git -C "$WT_PATH" checkout -- README.md

section "wt finish — error when run from main checkout"
cd "$REPO"
out=$(wt finish 2>&1 || true)
assert_contains "errors when not in a worktree" "main checkout" "$out"

# ── wt abandon — dirty worktree ──────────────────────────────────────────────
section "wt abandon — dirty worktree double-confirm"
cd "$REPO"
WT_PATH_DIRTY="${REPO}/.worktrees/dirty-drop-test"
stdout_dd=$(wt new "dirty drop test" 2>/dev/null)
assert_eq "created dirty abandon worktree" "$WT_PATH_DIRTY" "$stdout_dd"
cd "$WT_PATH_DIRTY"
echo "uncommitted" > dirty-file.txt
out=$(printf "y\ny\n" | wt abandon 2>&1)
assert_contains   "abandon reports success"  "Dropped"  "$out"
assert_dir_not_exists "dirty worktree removed" "$WT_PATH_DIRTY"
branch_dd=$(git -C "$REPO" rev-parse --verify "wt/dirty-drop-test" 2>/dev/null || echo "gone")
assert_eq         "dirty branch deleted"  "gone" "$branch_dd"

# ── wt abandon ───────────────────────────────────────────────────────────────
section "wt abandon — abandons worktree without merging"
# its-a-tricky-description has no dirty files (.wt-meta excluded), so only one confirm prompt
cd "$WT_PATH2"
_tmp_err2=$(mktemp)
stdout_drop=$(printf "y\n" | wt abandon 2>"$_tmp_err2")
out=$(cat "$_tmp_err2"); rm -f "$_tmp_err2"
assert_contains    "abandon reports success"        "Dropped"  "$out"
assert_eq          "abandon stdout is main worktree path" "$REPO" "$stdout_drop"
assert_dir_not_exists "worktree dir removed"     "$WT_PATH2"
branch_exists=$(git -C "$REPO" rev-parse --verify "wt/its-a-tricky-description" 2>/dev/null || echo "gone")
assert_eq          "branch force-deleted"        "gone" "$branch_exists"

# ── wt finish — rebase + fast-forward ────────────────────────────────────────
section "wt finish — rebase + fast-forward"
cd "$REPO"
git -C "$REPO" checkout -q dev
WT_PATH_FF="${REPO}/.worktrees/ff-test-task"
stdout_ff=$(wt new "ff test task" 2>/dev/null)
assert_eq "stdout is ff worktree path" "$WT_PATH_FF" "$stdout_ff"
echo "ff" > "${WT_PATH_FF}/ff.txt"
git -C "$WT_PATH_FF" add ff.txt
git -C "$WT_PATH_FF" commit -q -m "ff commit"
# Switch main checkout to main (not dev) so dev ref can be fast-forwarded
git -C "$REPO" checkout -q main
cd "$WT_PATH_FF"
_tmp_ff=$(mktemp)
stdout_ff=$(printf "y\n" | wt finish 2>"$_tmp_ff")
out_ff=$(cat "$_tmp_ff"); rm -f "$_tmp_ff"
assert_contains       "rebase reported"          "Rebase successful" "$out_ff"
assert_contains       "fast-forward reported"    "Fast-forward" "$out_ff"
assert_eq             "finish stdout is main worktree path" "$REPO" "$stdout_ff"
assert_dir_not_exists "ff worktree removed"      "$WT_PATH_FF"
branch_ff=$(git -C "$REPO" rev-parse --verify "wt/ff-test-task" 2>/dev/null || echo "gone")
assert_eq             "ff branch deleted"        "gone" "$branch_ff"
# Verify ff commit landed on dev
git -C "$REPO" checkout -q dev
assert_contains "ff commit landed on dev" "ff commit" "$(git -C "$REPO" log --oneline -5)"

# ── wt finish — rebase when base has diverged ────────────────────────────────
section "wt finish — rebase when base has diverged"
cd "$REPO"
git -C "$REPO" checkout -q dev
# Add a commit to dev AFTER the worktree was created (simulates divergence)
echo "base-change" > "${REPO}/base-change.txt"
git -C "$REPO" add base-change.txt
git -C "$REPO" commit -q -m "base diverged"
cd "$WT_PATH"
echo "fix" > fix.txt
git -C "$WT_PATH" add fix.txt
git -C "$WT_PATH" commit -q -m "fix sidebar overflow"

_tmp_err=$(mktemp)
stdout_done=$(printf "y\n" | wt finish 2>"$_tmp_err")
out=$(cat "$_tmp_err"); rm -f "$_tmp_err"
assert_contains       "finish reports success"         "Done!" "$out"
assert_contains       "rebase performed"               "Rebase successful" "$out"
assert_eq             "finish stdout is main worktree path" "$REPO" "$stdout_done"
assert_dir_not_exists "worktree dir removed"           "$WT_PATH"
branch_exists=$(git -C "$REPO" rev-parse --verify "wt/fix-the-sidebar-overflow-bug" 2>/dev/null || echo "gone")
assert_eq             "branch deleted"                 "gone" "$branch_exists"

# Verify linear history — no merge commits
git -C "$REPO" checkout -q dev 2>/dev/null
commit_log=$(git -C "$REPO" log --oneline -5)
assert_contains     "fix commit landed on dev"   "fix sidebar overflow" "$commit_log"
assert_not_contains "no merge commits"           "Merge" "$commit_log"

# ── wt finish --yes ───────────────────────────────────────────────────────────
section "wt finish --yes — skips confirmation (no stdin pipe)"
cd "$REPO"
git -C "$REPO" checkout -q dev
WT_PATH_FY="${REPO}/.worktrees/finish-yes-test"
stdout_fy=$(wt new "finish yes test" 2>/dev/null)
assert_eq "created finish-yes worktree" "$WT_PATH_FY" "$stdout_fy"
echo "yes-work" > "${WT_PATH_FY}/yes-work.txt"
git -C "$WT_PATH_FY" add yes-work.txt
git -C "$WT_PATH_FY" commit -q -m "yes test commit"
git -C "$REPO" checkout -q main
cd "$WT_PATH_FY"
_tmp_fy=$(mktemp)
stdout_fin_yes=$(wt finish --yes 2>"$_tmp_fy")
out_fin_yes=$(cat "$_tmp_fy"); rm -f "$_tmp_fy"
assert_contains       "finish --yes reports success"  "Done!"  "$out_fin_yes"
assert_eq             "stdout is main worktree path"  "$REPO"  "$stdout_fin_yes"
assert_dir_not_exists "worktree removed"              "$WT_PATH_FY"
branch_fy=$(git -C "$REPO" rev-parse --verify "wt/finish-yes-test" 2>/dev/null || echo "gone")
assert_eq             "branch deleted"                "gone"   "$branch_fy"

# ── wt finish — uses origin/<base> when local base is behind ──────────────────
# Regression: old wt finish rebased onto local base_branch directly, causing
# conflicts when local base was behind origin. Should use origin/<base> instead.
section "wt finish — uses origin/base when local base is stale"
cd "$REPO"
git -C "$REPO" checkout -q dev

# Create a bare remote and set origin on the test repo
BARE_FIN="${TMPROOT}/bare-fin.git"
git -C "$REPO" clone --bare . "$BARE_FIN" 2>/dev/null
git -C "$REPO" remote add origin "$BARE_FIN" 2>/dev/null || git -C "$REPO" remote set-url origin "$BARE_FIN"

# Advance the remote's dev branch (simulates origin moving ahead of local)
git -C "$BARE_FIN" branch -f dev HEAD 2>/dev/null || true
# Push a new commit to the bare remote so origin/dev is ahead of local dev
ADVANCE_WD="${TMPROOT}/advance-wd"
git clone "$BARE_FIN" "$ADVANCE_WD" -q 2>/dev/null
echo "remote-advance" > "${ADVANCE_WD}/remote-advance.txt"
git -C "$ADVANCE_WD" add remote-advance.txt
git -C "$ADVANCE_WD" commit -q -m "remote advance commit"
git -C "$ADVANCE_WD" push -q 2>/dev/null
rm -rf "$ADVANCE_WD"

# Fetch so origin/dev is known but do NOT merge — local dev stays behind
git -C "$REPO" fetch origin dev 2>/dev/null

# Create worktree from local dev (which is now behind origin/dev)
WT_PATH_FOS="${REPO}/.worktrees/finish-origin-stale"
wt new "finish origin stale" 2>/dev/null
echo "my-work" > "${WT_PATH_FOS}/my-work.txt"
git -C "$WT_PATH_FOS" add my-work.txt
git -C "$WT_PATH_FOS" commit -q -m "work on stale base"

cd "$WT_PATH_FOS"
_tmp_fos=$(mktemp)
stdout_fos=$(wt finish --yes 2>"$_tmp_fos")
out_fos=$(cat "$_tmp_fos"); rm -f "$_tmp_fos"
assert_contains       "finish succeeds despite stale local base" "Done!"  "$out_fos"
assert_eq             "finish stdout is main worktree path"      "$REPO"  "$stdout_fos"
assert_dir_not_exists "worktree removed"                         "$WT_PATH_FOS"
branch_fos=$(git -C "$REPO" rev-parse --verify "wt/finish-origin-stale" 2>/dev/null || echo "gone")
assert_eq             "branch deleted"                           "gone"   "$branch_fos"
# Verify the remote-advance commit is now in local dev (base was ff'd to origin/dev tip)
git -C "$REPO" checkout -q dev
assert_contains "remote-advance commit landed on dev" "remote advance commit" \
  "$(git -C "$REPO" log --oneline -5)"

git -C "$REPO" remote remove origin 2>/dev/null || true
rm -rf "$BARE_FIN"

# ── wt finish — PR-flow detection ─────────────────────────────────────────────

MOCK_BIN_FIN="${TMPROOT}/mock-bin-fin"
mkdir -p "$MOCK_BIN_FIN"
cat > "${MOCK_BIN_FIN}/gh" << 'MOCKEOF_FIN'
#!/usr/bin/env bash
echo "$@" >> "${MOCK_BIN_FIN_PATH}/gh-calls.log"
if [[ "$1" == "pr" && "$2" == "view" ]]; then
  echo "MERGED"
fi
MOCKEOF_FIN
sed -i.bak "s|\${MOCK_BIN_FIN_PATH}|${MOCK_BIN_FIN}|g" "${MOCK_BIN_FIN}/gh" && rm "${MOCK_BIN_FIN}/gh.bak"
chmod +x "${MOCK_BIN_FIN}/gh"

section "wt finish — PR merged skips rebase"
cd "$REPO"
git -C "$REPO" checkout -q dev
WT_PATH_FM="${REPO}/.worktrees/finish-merged-test"
stdout_fm=$(wt new "finish merged test" 2>/dev/null)
assert_eq "created finish-merged worktree" "$WT_PATH_FM" "$stdout_fm"
echo "pr-merged-work" > "${WT_PATH_FM}/pr-merged.txt"
git -C "$WT_PATH_FM" add pr-merged.txt
git -C "$WT_PATH_FM" commit -q -m "PR merged test commit"
cd "$WT_PATH_FM"
rm -f "${MOCK_BIN_FIN}/gh-calls.log"
_tmp_fm=$(mktemp)
stdout_fin_m=$(printf "y\n" | PATH="${MOCK_BIN_FIN}:${PATH}" WT_REGISTRY="$registry_file" bash "$WT" finish 2>"$_tmp_fm")
out_fin_m=$(cat "$_tmp_fm"); rm -f "$_tmp_fm"
assert_contains       "reports PR merged"     "PR merged"  "$out_fin_m"
assert_contains       "reports Done"          "Done!"      "$out_fin_m"
assert_eq             "stdout is main path"   "$REPO"      "$stdout_fin_m"
assert_dir_not_exists "worktree removed"      "$WT_PATH_FM"
branch_fm=$(git -C "$REPO" rev-parse --verify "wt/finish-merged-test" 2>/dev/null || echo "gone")
assert_eq             "branch deleted"        "gone"       "$branch_fm"
gh_log_fin=$(cat "${MOCK_BIN_FIN}/gh-calls.log" 2>/dev/null || echo "")
assert_contains       "gh pr view called"     "pr view"    "$gh_log_fin"
assert_not_contains   "rebase skipped"        "Rebase"     "$out_fin_m"

section "wt finish — PR open blocks finish"
cd "$REPO"
git -C "$REPO" checkout -q dev
WT_PATH_FO="${REPO}/.worktrees/finish-open-test"
stdout_fo=$(wt new "finish open test" 2>/dev/null)
assert_eq "created finish-open worktree" "$WT_PATH_FO" "$stdout_fo"
echo "pr-open-work" > "${WT_PATH_FO}/pr-open.txt"
git -C "$WT_PATH_FO" add pr-open.txt
git -C "$WT_PATH_FO" commit -q -m "PR open test commit"
cat > "${MOCK_BIN_FIN}/gh" << 'MOCKEOF_FIN_O'
#!/usr/bin/env bash
if [[ "$1" == "pr" && "$2" == "view" ]]; then
  echo "OPEN"
fi
MOCKEOF_FIN_O
chmod +x "${MOCK_BIN_FIN}/gh"
cd "$WT_PATH_FO"
_tmp_fo=$(mktemp)
PATH="${MOCK_BIN_FIN}:${PATH}" WT_REGISTRY="$registry_file" bash "$WT" finish 2>"$_tmp_fo" || true
out_fin_o=$(cat "$_tmp_fo"); rm -f "$_tmp_fo"
assert_contains "errors on open PR" "still open" "$out_fin_o"
git -C "$REPO" worktree remove "$WT_PATH_FO" --force 2>/dev/null || true
git -C "$REPO" branch -D "wt/finish-open-test" 2>/dev/null || true

section "wt finish --yes — PR merged skips confirm"
cd "$REPO"
git -C "$REPO" checkout -q dev
WT_PATH_FMY="${REPO}/.worktrees/finish-merged-yes-test"
stdout_fmy=$(wt new "finish merged yes test" 2>/dev/null)
assert_eq "created finish-merged-yes worktree" "$WT_PATH_FMY" "$stdout_fmy"
echo "pr-merged-yes" > "${WT_PATH_FMY}/pr-merged-yes.txt"
git -C "$WT_PATH_FMY" add pr-merged-yes.txt
git -C "$WT_PATH_FMY" commit -q -m "PR merged --yes test commit"
cat > "${MOCK_BIN_FIN}/gh" << 'MOCKEOF_FIN_M'
#!/usr/bin/env bash
if [[ "$1" == "pr" && "$2" == "view" ]]; then
  echo "MERGED"
fi
MOCKEOF_FIN_M
chmod +x "${MOCK_BIN_FIN}/gh"
cd "$WT_PATH_FMY"
_tmp_fmy=$(mktemp)
stdout_fin_my=$(PATH="${MOCK_BIN_FIN}:${PATH}" WT_REGISTRY="$registry_file" bash "$WT" finish --yes 2>"$_tmp_fmy")
out_fin_my=$(cat "$_tmp_fmy"); rm -f "$_tmp_fmy"
assert_contains       "cleanup succeeds"      "Done!"           "$out_fin_my"
assert_eq             "stdout is main path"   "$REPO"           "$stdout_fin_my"
assert_dir_not_exists "worktree removed"      "$WT_PATH_FMY"
branch_fmy=$(git -C "$REPO" rev-parse --verify "wt/finish-merged-yes-test" 2>/dev/null || echo "gone")
assert_eq             "branch deleted"        "gone"            "$branch_fmy"

rm -rf "$MOCK_BIN_FIN"

# ── wt abandon --yes ──────────────────────────────────────────────────────────
section "wt abandon --yes — clean worktree (no stdin pipe)"
cd "$REPO"
git -C "$REPO" checkout -q dev
WT_PATH_DY="${REPO}/.worktrees/drop-yes-test"
stdout_dy=$(wt new "drop yes test" 2>/dev/null)
assert_eq "created abandon-yes worktree" "$WT_PATH_DY" "$stdout_dy"
cd "$WT_PATH_DY"
_tmp_dy=$(mktemp)
stdout_drop_yes=$(wt abandon --yes 2>"$_tmp_dy")
out_drop_yes=$(cat "$_tmp_dy"); rm -f "$_tmp_dy"
assert_contains       "abandon --yes reports success"  "Dropped"  "$out_drop_yes"
assert_eq             "stdout is main worktree path"   "$REPO"    "$stdout_drop_yes"
assert_dir_not_exists "worktree removed"               "$WT_PATH_DY"
branch_dy=$(git -C "$REPO" rev-parse --verify "wt/drop-yes-test" 2>/dev/null || echo "gone")
assert_eq             "branch deleted"                 "gone"     "$branch_dy"

section "wt abandon --yes — dirty worktree (skips both confirms)"
cd "$REPO"
git -C "$REPO" checkout -q dev
WT_PATH_DDY="${REPO}/.worktrees/drop-dirty-yes-test"
stdout_ddy=$(wt new "drop dirty yes test" 2>/dev/null)
assert_eq "created abandon-dirty-yes worktree" "$WT_PATH_DDY" "$stdout_ddy"
echo "uncommitted" > "${WT_PATH_DDY}/dirty-yes.txt"
cd "$WT_PATH_DDY"
_tmp_ddy=$(mktemp)
stdout_ddy_out=$(wt abandon --yes 2>"$_tmp_ddy")
out_ddy=$(cat "$_tmp_ddy"); rm -f "$_tmp_ddy"
assert_contains       "abandon --yes dirty reports success"  "Dropped"  "$out_ddy"
assert_dir_not_exists "dirty worktree removed"               "$WT_PATH_DDY"

section "wt abandon -y — short flag works"
cd "$REPO"
git -C "$REPO" checkout -q dev
WT_PATH_SY="${REPO}/.worktrees/short-yes-test"
stdout_sy=$(wt new "short yes test" 2>/dev/null)
assert_eq "created short-yes worktree" "$WT_PATH_SY" "$stdout_sy"
cd "$WT_PATH_SY"
_tmp_sy=$(mktemp)
stdout_sy_drop=$(wt abandon -y 2>"$_tmp_sy"); rm -f "$_tmp_sy"
assert_eq             "stdout is main worktree path"  "$REPO"  "$stdout_sy_drop"
assert_dir_not_exists "worktree removed"              "$WT_PATH_SY"

# ── wt sync ───────────────────────────────────────────────────────────────────
section "wt sync — error from main checkout"
cd "$REPO"
out_main=$(wt sync 2>&1 || true)
assert_contains "errors when not in a worktree" "main checkout" "$out_main"

section "wt sync — rebases onto diverged base"
cd "$REPO"
git -C "$REPO" checkout -q dev
WT_PATH_SYNC="${REPO}/.worktrees/sync-test"
wt new "sync test" 2>/dev/null
# Make a commit in the worktree
echo "wt-work" > "${WT_PATH_SYNC}/wt-work.txt"
git -C "$WT_PATH_SYNC" add wt-work.txt
git -C "$WT_PATH_SYNC" commit -q -m "worktree commit"
# Advance the base branch (simulates divergence)
git -C "$REPO" checkout -q dev
echo "base-advance" > "${REPO}/base-advance.txt"
git -C "$REPO" add base-advance.txt
git -C "$REPO" commit -q -m "base advanced"
# Sync from worktree (no remote — falls back to local ref)
cd "$WT_PATH_SYNC"
out_sync=$(wt sync 2>&1)
assert_contains "sync reports success" "Synced" "$out_sync"
# Verify base commit is reachable in worktree
assert_contains "base commit reachable" "base advanced" "$(git -C "$WT_PATH_SYNC" log --oneline -5)"
# Verify worktree commit still present
assert_contains "worktree commit preserved" "worktree commit" "$(git -C "$WT_PATH_SYNC" log --oneline -5)"
# Verify linear history (no merge commits)
assert_not_contains "no merge commits" "Merge" "$(git -C "$WT_PATH_SYNC" log --oneline -10)"
# Verify worktree still exists (sync doesn't clean up)
assert_dir_exists "worktree still intact" "$WT_PATH_SYNC"

section "wt sync — already up to date"
cd "$WT_PATH_SYNC"
out_uptodate=$(wt sync 2>&1)
assert_contains "sync succeeds when up to date" "Synced" "$out_uptodate"

section "wt sync — blocks on dirty worktree"
cd "$WT_PATH_SYNC"
echo "dirty" > dirty-sync.txt
out_dirty=$(wt sync 2>&1 || true)
assert_contains "blocks on uncommitted changes" "Uncommitted changes" "$out_dirty"
rm dirty-sync.txt

# Clean up sync worktree
cd "$REPO"
git -C "$REPO" checkout -q dev
git -C "$REPO" worktree remove "$WT_PATH_SYNC" --force 2>/dev/null || true
git -C "$REPO" branch -D "wt/sync-test" 2>/dev/null || true

# ── wt list — empty after cleanup ────────────────────────────────────────────
section "wt list — empty after all worktrees cleaned up"
# Clean up remaining worktrees from earlier tests
if [[ -d "${REPO}/.worktrees/new-from-inside-worktree" ]]; then
  git -C "$REPO" worktree remove "${REPO}/.worktrees/new-from-inside-worktree" --force 2>/dev/null || true
  git -C "$REPO" branch -D "wt/new-from-inside-worktree" 2>/dev/null || true
fi
# "No active worktrees" goes to stderr (via info()), so capture both
list_out=$(wt list 2>&1)
assert_contains "shows 'no worktrees' message" "No active worktrees" "$list_out"

# ── wt doctor ────────────────────────────────────────────────────────────────
section "wt doctor — clean repo reports all good"
cd "$REPO"
out=$(printf "n\n" | wt doctor 2>&1) || true
assert_contains "reports no issues when clean" "all good" "$out"

section "wt doctor — orphaned branch detected and fixed"
git -C "$REPO" branch wt/orphan-branch 2>/dev/null
out=$(printf "n\n" | wt doctor 2>&1) || true
assert_contains "reports orphaned branch" "orphan-branch" "$out"
# Fix it
printf "y\n" | wt doctor 2>/dev/null || true
branch_orphan=$(git -C "$REPO" rev-parse --verify "wt/orphan-branch" 2>/dev/null || echo "gone")
assert_eq "orphaned branch deleted after fix" "gone" "$branch_orphan"

section "wt doctor — orphaned worktree dir detected and fixed"
mkdir -p "${REPO}/.worktrees/ghost-dir"
printf "base_branch=dev\nbranch=wt/ghost-dir\nslug=ghost-dir\n" > "${REPO}/.worktrees/ghost-dir/.wt-meta"
out=$(printf "n\n" | wt doctor 2>&1) || true
assert_contains "reports orphaned dir" "ghost-dir" "$out"
# Fix it
printf "y\n" | wt doctor 2>/dev/null || true
assert_dir_not_exists "ghost dir removed after fix" "${REPO}/.worktrees/ghost-dir"

section "wt doctor — corrupt .wt-meta detected"
# Register a real worktree so check 2 (orphaned dir) doesn't fire — only check 3 (corrupt meta) fires
git -C "$REPO" worktree add "${REPO}/.worktrees/corrupt-wt" -b "wt/corrupt-wt" >/dev/null 2>&1
echo "base_branch=dev" > "${REPO}/.worktrees/corrupt-wt/.wt-meta"  # overwrite with corrupt meta (missing branch+slug)
# No confirm prompts for this run — use temp file to avoid pipe stdout-swallowing issue
_tmp_doc=$(mktemp)
wt doctor > "$_tmp_doc" 2>&1 < /dev/null || true
out=$(cat "$_tmp_doc"); rm -f "$_tmp_doc"
assert_contains "reports corrupt meta" "Corrupt" "$out"
git -C "$REPO" worktree remove "${REPO}/.worktrees/corrupt-wt" --force 2>/dev/null
git -C "$REPO" branch -D "wt/corrupt-wt" 2>/dev/null

section "wt doctor — missing info/exclude entries fixed"
# Remove .worktrees/ from info/exclude to simulate missing entry
EXCLUDE_FILE="${REPO}/.git/info/exclude"
grep -v "^\.worktrees/$" "$EXCLUDE_FILE" > "${EXCLUDE_FILE}.tmp" && mv "${EXCLUDE_FILE}.tmp" "$EXCLUDE_FILE"
out=$(printf "n\n" | wt doctor 2>&1) || true
assert_contains "reports missing exclude entry" ".worktrees/" "$out"
# Fix it
printf "y\n" | wt doctor 2>/dev/null || true
assert_contains ".worktrees/ restored in exclude" ".worktrees/" "$(cat "$EXCLUDE_FILE")"

section "wt list — stale registry entry skipped silently"
echo "/nonexistent/stale/path/in/registry" >> "$registry_file"
list_stale=$(wt list 2>&1 || true)
assert_not_contains "stale path not shown in list output" "/nonexistent/stale/path" "$list_stale"

section "wt doctor — stale git worktree registration detected"
# Simulate a stale registration by creating and then manually removing a worktree dir
STALE_PATH="${REPO}/.worktrees/stale-wt"
git -C "$REPO" worktree add "$STALE_PATH" -b "wt/stale-wt" >/dev/null 2>&1
rm -rf "$STALE_PATH"  # remove dir without pruning
out=$(printf "n\n" | wt doctor 2>&1) || true
assert_contains "reports stale registration" "stale" "$out"
# Fix it
printf "y\n" | wt doctor 2>/dev/null || true
stale_branch=$(git -C "$REPO" rev-parse --verify "wt/stale-wt" 2>/dev/null || echo "gone")
assert_eq "stale branch cleaned up after fix" "gone" "$stale_branch"

section "wt doctor — stale registry entry detected and removed"
# The /nonexistent/stale/path/in/registry entry added earlier should still be present
out=$(printf "n\n" | wt doctor 2>&1) || true
assert_contains "reports stale registry entry" "Stale registry" "$out"
# Fix it
printf "y\n" | wt doctor 2>/dev/null || true
assert_not_contains "stale entry removed from registry" "/nonexistent/stale/path" "$(cat "$registry_file" 2>/dev/null)"

