# ─── finish/pr — squash path after wt update ─────────────────────────────────
# Isolated project so state doesn't pollute main REPO tests.
SQ_PROJ="${TMPROOT}/sq-proj"
mkdir -p "$SQ_PROJ"
git -C "$SQ_PROJ" init -q -b main
git -C "$SQ_PROJ" config user.email "test@test.com"
git -C "$SQ_PROJ" config user.name "Test"
echo "init" > "$SQ_PROJ/README.md"
git -C "$SQ_PROJ" add README.md
git -C "$SQ_PROJ" commit -q -m "initial"
git -C "$SQ_PROJ" checkout -q -b dev
echo "dev-content" > "$SQ_PROJ/dev.txt"
git -C "$SQ_PROJ" add dev.txt
git -C "$SQ_PROJ" commit -q -m "dev commit"
git -C "$SQ_PROJ" checkout -q main

section "wt finish — squash merge after wt update"
cd "$SQ_PROJ"
git -C "$SQ_PROJ" checkout -q dev
SQ_WT="${SQ_PROJ}/.worktrees/sq-test-task"
wt new "sq test task" 2>/dev/null
# Commit in worktree
echo "wt-work" > "${SQ_WT}/wt-work.txt"
git -C "$SQ_WT" add wt-work.txt
git -C "$SQ_WT" commit -q -m "worktree work"
# Advance dev (different file — no conflict)
git -C "$SQ_PROJ" checkout -q dev
echo "base-advance" > "${SQ_PROJ}/base-advance.txt"
git -C "$SQ_PROJ" add base-advance.txt
git -C "$SQ_PROJ" commit -q -m "base advanced"
git -C "$SQ_PROJ" checkout -q main  # leave dev free for ff
dev_sq_before=$(git -C "$SQ_PROJ" rev-parse dev)
# wt update → merge commit
cd "$SQ_WT"
wt update 2>/dev/null
merge_check=$(git -C "$SQ_WT" rev-list --merges "dev..HEAD" | head -1)
[[ -n "$merge_check" ]] \
  && pass "sanity: merge commit present after wt update" \
  || fail "sanity: no merge commit found after wt update"
# wt finish --yes → squash path
_tmp_sq=$(mktemp)
stdout_sq=$(wt finish --yes 2>"$_tmp_sq")
out_sq=$(cat "$_tmp_sq"); rm -f "$_tmp_sq"
assert_contains       "squash finish reports Done"           "Done!"        "$out_sq"
assert_contains       "squash finish uses squash strategy"   "squash"       "$out_sq"
assert_eq             "finish stdout is main worktree path"  "$SQ_PROJ"     "$stdout_sq"
assert_dir_not_exists "sq worktree removed"                  "$SQ_WT"
branch_sq=$(git -C "$SQ_PROJ" rev-parse --verify "wt/sq-test-task" 2>/dev/null || echo "gone")
assert_eq             "sq branch deleted"                    "gone"         "$branch_sq"
# Exactly 1 new commit on dev (the squash — not 2 separate commits)
sq_new_count=$(git -C "$SQ_PROJ" rev-list "${dev_sq_before}..dev" | wc -l | tr -d ' ')
assert_eq             "exactly 1 squash commit on dev"       "1"            "$sq_new_count"
# Squash commit message matches description
sq_msg=$(git -C "$SQ_PROJ" log -1 --format="%s" dev)
assert_eq             "squash commit message is description" "sq test task" "$sq_msg"
# Worktree files landed on dev
git -C "$SQ_PROJ" checkout -q dev
assert_file_exists    "wt-work.txt landed on dev"            "${SQ_PROJ}/wt-work.txt"
assert_file_exists    "base-advance.txt landed on dev"       "${SQ_PROJ}/base-advance.txt"
git -C "$SQ_PROJ" checkout -q main

section "wt finish — squash pre-flight error when base advanced after update"
cd "$SQ_PROJ"
git -C "$SQ_PROJ" checkout -q dev
SQ_PRE_WT="${SQ_PROJ}/.worktrees/sq-preflight-test"
wt new "sq preflight test" 2>/dev/null
echo "wt-pf-work" > "${SQ_PRE_WT}/wt-pf-work.txt"
git -C "$SQ_PRE_WT" add wt-pf-work.txt
git -C "$SQ_PRE_WT" commit -q -m "preflight work"
# Advance dev (diverge)
git -C "$SQ_PROJ" checkout -q dev
echo "base-pf1" > "${SQ_PROJ}/base-pf1.txt"
git -C "$SQ_PROJ" add base-pf1.txt
git -C "$SQ_PROJ" commit -q -m "base pf advance 1"
git -C "$SQ_PROJ" checkout -q main
# wt update → merge (base is now ancestor of HEAD)
cd "$SQ_PRE_WT"
wt update 2>/dev/null
# Advance dev AGAIN after update → base is no longer ancestor of HEAD
git -C "$SQ_PROJ" checkout -q dev
echo "base-pf2" > "${SQ_PROJ}/base-pf2.txt"
git -C "$SQ_PROJ" add base-pf2.txt
git -C "$SQ_PROJ" commit -q -m "base pf advance 2"
git -C "$SQ_PROJ" checkout -q main
# wt finish --yes → squash path detected (merge commits exist), pre-flight fails
cd "$SQ_PRE_WT"
_tmp_sq_pre=$(mktemp)
wt finish --yes 2>"$_tmp_sq_pre" || true
out_sq_pre=$(cat "$_tmp_sq_pre"); rm -f "$_tmp_sq_pre"
assert_contains   "squash pre-flight shows wt update instruction" "wt update" "$out_sq_pre"
assert_dir_exists "sq preflight worktree preserved on error"       "$SQ_PRE_WT"
# Cleanup
cd "$SQ_PROJ"
git -C "$SQ_PROJ" worktree remove "$SQ_PRE_WT" --force 2>/dev/null || true
git -C "$SQ_PROJ" branch -D "wt/sq-preflight-test" 2>/dev/null || true

section "wt pr — skips rebase when merge commits present"
SQ_PR_PROJ="${TMPROOT}/sq-pr-proj"
mkdir -p "$SQ_PR_PROJ"
git -C "$SQ_PR_PROJ" init -q -b main
git -C "$SQ_PR_PROJ" config user.email "test@test.com"
git -C "$SQ_PR_PROJ" config user.name "Test"
echo "init" > "$SQ_PR_PROJ/README.md"
git -C "$SQ_PR_PROJ" add README.md
git -C "$SQ_PR_PROJ" commit -q -m "initial"
git -C "$SQ_PR_PROJ" checkout -q -b dev
echo "dev-content" > "$SQ_PR_PROJ/dev.txt"
git -C "$SQ_PR_PROJ" add dev.txt
git -C "$SQ_PR_PROJ" commit -q -m "dev commit"
git -C "$SQ_PR_PROJ" checkout -q dev
SQ_PR_BARE="${TMPROOT}/sq-pr-bare.git"
git -C "$SQ_PR_PROJ" clone --bare . "$SQ_PR_BARE" 2>/dev/null
SQ_PR_WT="${SQ_PR_PROJ}/.worktrees/sq-pr-test"
cd "$SQ_PR_PROJ"
wt new "sq pr test" 2>/dev/null
git -C "$SQ_PR_WT" remote add origin "$SQ_PR_BARE"
echo "pr-work" > "${SQ_PR_WT}/pr-work.txt"
git -C "$SQ_PR_WT" add pr-work.txt
git -C "$SQ_PR_WT" commit -q -m "pr work commit"
# Advance dev (diverge)
git -C "$SQ_PR_PROJ" checkout -q dev
echo "dev-advance" > "${SQ_PR_PROJ}/dev-advance.txt"
git -C "$SQ_PR_PROJ" add dev-advance.txt
git -C "$SQ_PR_PROJ" commit -q -m "dev advanced"
git -C "$SQ_PR_PROJ" checkout -q main
# wt update → merge commit
cd "$SQ_PR_WT"
wt update 2>/dev/null
# Mock gh
SQ_PR_MOCK="${TMPROOT}/sq-pr-mock"
mkdir -p "$SQ_PR_MOCK"
cat > "${SQ_PR_MOCK}/gh" << 'SQ_PR_MOCKEOF'
#!/usr/bin/env bash
if [[ "$1" == "pr" && "$2" == "view" ]]; then exit 1; fi
if [[ "$1" == "pr" && "$2" == "create" ]]; then echo "https://github.com/test/test/pull/99"; fi
SQ_PR_MOCKEOF
chmod +x "${SQ_PR_MOCK}/gh"
cd "$SQ_PR_WT"
_tmp_sq_pr=$(mktemp)
stdout_sq_pr=$(PATH="${SQ_PR_MOCK}:${PATH}" WT_REGISTRY="$registry_file" bash "$WT" pr --yes 2>"$_tmp_sq_pr")
out_sq_pr=$(cat "$_tmp_sq_pr"); rm -f "$_tmp_sq_pr"
assert_not_contains "pr skips rebase with merge commits"  "Rebased"            "$out_sq_pr"
assert_contains     "pr still creates PR"                 "PR created"         "$out_sq_pr"
assert_contains     "pr returns URL on stdout"            "https://github.com" "$stdout_sq_pr"
# Cleanup
cd "$SQ_PR_PROJ"
git -C "$SQ_PR_PROJ" worktree remove "$SQ_PR_WT" --force 2>/dev/null || true
git -C "$SQ_PR_PROJ" branch -D "wt/sq-pr-test" 2>/dev/null || true
rm -rf "$SQ_PR_MOCK" "$SQ_PR_BARE"

# ─── Summary ─────────────────────────────────────────────────────────────────

echo ""
echo -e "${BOLD}────────────────────────────────${RESET}"
total=$(( PASS + FAIL ))
echo -e "  ${GREEN}${PASS} passed${RESET}  ${RED}${FAIL} failed${RESET}  (${total} total)"
echo -e "${BOLD}────────────────────────────────${RESET}"

(( FAIL == 0 ))
