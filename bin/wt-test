git -C "$UPD_PROJ" branch -D "wt/upd-untrack" 2>/dev/null || true
git -C "$UPD_PROJ" checkout -q main

section "wt update — conflict detected, files listed"
cd "$UPD_PROJ"
git -C "$UPD_PROJ" checkout -q dev
# Add multi-line data.txt to dev for auto-merge test
printf "line1\nline2\nline3\n" > "${UPD_PROJ}/data.txt"
git -C "$UPD_PROJ" add data.txt
git -C "$UPD_PROJ" commit -q -m "add data.txt"
UPD_WT_CONFLICT="${UPD_PROJ}/.worktrees/upd-conflict"
wt new "upd conflict" 2>/dev/null
# Worktree: change README.md (conflict) + append to data.txt (auto-merge)
echo "worktree-change" > "${UPD_WT_CONFLICT}/README.md"
printf "line1\nline2\nline3\nwt-appended\n" > "${UPD_WT_CONFLICT}/data.txt"
git -C "$UPD_WT_CONFLICT" add README.md data.txt
git -C "$UPD_WT_CONFLICT" commit -q -m "wt changed readme"
# Base: change README.md (conflict) + prepend to data.txt (auto-merge)
git -C "$UPD_PROJ" checkout -q dev
echo "base-change" > "${UPD_PROJ}/README.md"
printf "base-prepended\nline1\nline2\nline3\n" > "${UPD_PROJ}/data.txt"
git -C "$UPD_PROJ" add README.md data.txt
git -C "$UPD_PROJ" commit -q -m "base changed readme"
git -C "$UPD_PROJ" checkout -q main
cd "$UPD_WT_CONFLICT"
out_conflict=$(wt update 2>&1 || true)
assert_contains "reports conflict" "conflict" "$out_conflict"
assert_contains "lists conflicted file" "README.md" "$out_conflict"
assert_contains "shows conflict line number" "README.md:1" "$out_conflict"
assert_contains "shows conflict count" "1 conflict" "$out_conflict"
assert_contains "shows auto-merged summary" "Auto-merged:" "$out_conflict"
assert_contains "lists auto-merged file" "data.txt" "$out_conflict"
assert_contains "shows HEAD commit subject" "wt changed readme" "$out_conflict"
assert_contains "shows base commit subject" "base changed readme" "$out_conflict"
assert_contains "shows merge continue instruction" "git merge --continue" "$out_conflict"
git -C "$UPD_WT_CONFLICT" merge --abort 2>/dev/null || true
cd "$UPD_PROJ"
git -C "$UPD_PROJ" worktree remove "$UPD_WT_CONFLICT" --force 2>/dev/null || true
git -C "$UPD_PROJ" branch -D "wt/upd-conflict" 2>/dev/null || true
git -C "$UPD_PROJ" checkout -q main

section "wt update — errors when base branch not found locally"
