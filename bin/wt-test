git -C "$UPD_WT_MERGE" add wt-work.txt
git -C "$UPD_WT_MERGE" commit -q -m "worktree work"
git -C "$UPD_PROJ" checkout -q dev
echo "base-advance" > "${UPD_PROJ}/base-advance.txt"
git -C "$UPD_PROJ" add base-advance.txt
git -C "$UPD_PROJ" commit -q -m "base advanced"
git -C "$UPD_PROJ" checkout -q main
cd "$UPD_WT_MERGE"
out_merge=$(wt update 2>&1)
assert_contains "reports success" "Merged" "$out_merge"
assert_contains "base commit reachable" "base advanced" "$(git -C "$UPD_WT_MERGE" log --oneline -5)"
assert_contains "worktree commit preserved" "worktree work" "$(git -C "$UPD_WT_MERGE" log --oneline -5)"
assert_contains "merge commit present" "Merge" "$(git -C "$UPD_WT_MERGE" log --oneline -5)"
stdout_merge=$(wt update 2>/dev/null)
assert_eq "no stdout from update" "" "$stdout_merge"
cd "$UPD_PROJ"
git -C "$UPD_PROJ" worktree remove "$UPD_WT_MERGE" --force 2>/dev/null || true
git -C "$UPD_PROJ" branch -D "wt/upd-merge" 2>/dev/null || true
git -C "$UPD_PROJ" checkout -q main

section "wt update — blocks on uncommitted tracked changes"
