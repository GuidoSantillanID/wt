section "wt update — clean merge from diverged base"
cd "$UPD_PROJ"
git -C "$UPD_PROJ" checkout -q dev
UPD_WT_MERGE="${UPD_PROJ}/.worktrees/upd-merge"
wt new "upd merge" 2>/dev/null
