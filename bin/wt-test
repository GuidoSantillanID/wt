# ─── C3: finish warns before destroying untracked files ──────────────────────

section "C3: wt finish — warns when untracked files present (confirms before --force)"
cd "$REPO"
git -C "$REPO" checkout -q dev
WT_UNTRACKED="${REPO}/.worktrees/untracked-finish-test"
WT_REGISTRY="$registry_file" bash "$WT" new "untracked finish test" 2>/dev/null
echo "committed" > "${WT_UNTRACKED}/committed.txt"
git -C "$WT_UNTRACKED" add committed.txt
git -C "$WT_UNTRACKED" commit -q -m "committed work"
# Add an untracked file that would be silently destroyed by --force
echo "precious untracked data" > "${WT_UNTRACKED}/untracked.txt"
cd "$WT_UNTRACKED"
# Say "n" to the untracked-file warning — should abort
out_c3=$(printf "n\n" | WT_REGISTRY="$registry_file" bash "$WT" finish 2>&1) || true
assert_contains "warns about untracked files" "Untracked files" "$out_c3"
assert_dir_exists "worktree preserved when user declines" "$WT_UNTRACKED"
assert_file_exists "untracked file preserved" "${WT_UNTRACKED}/untracked.txt"
# Now say "y" to untracked warning and "y" to proceed — should finish
git -C "$REPO" checkout -q main
out_c3y=$(printf "y\ny\n" | WT_REGISTRY="$registry_file" bash "$WT" finish 2>&1) || true
assert_contains "finish proceeds when user accepts" "Done!" "$out_c3y"
assert_dir_not_exists "worktree removed after accept" "$WT_UNTRACKED"

section "C3: wt finish --yes — untracked files are destroyed without prompt (auto-accept)"
cd "$REPO"
git -C "$REPO" checkout -q dev
WT_UNTRACKED2="${REPO}/.worktrees/untracked-yes-test"
WT_REGISTRY="$registry_file" bash "$WT" new "untracked yes test" 2>/dev/null
echo "committed2" > "${WT_UNTRACKED2}/committed2.txt"
git -C "$WT_UNTRACKED2" add committed2.txt
git -C "$WT_UNTRACKED2" commit -q -m "committed work 2"
echo "untracked data" > "${WT_UNTRACKED2}/untracked2.txt"
cd "$WT_UNTRACKED2"
git -C "$REPO" checkout -q main
out_c3y2=$(WT_REGISTRY="$registry_file" bash "$WT" finish --yes 2>&1) || true
assert_contains "finish --yes succeeds with untracked files" "Done!" "$out_c3y2"
assert_dir_not_exists "worktree removed with --yes" "$WT_UNTRACKED2"

# ─── S2: wt finish --force skips PR-open block ───────────────────────────────

section "S2: wt finish --force — skips PR-open check and finishes locally"
cd "$REPO"
git -C "$REPO" checkout -q dev
WT_FORCE="${REPO}/.worktrees/finish-force-test"
stdout_force=$(WT_REGISTRY="$registry_file" bash "$WT" new "finish force test" 2>/dev/null)
assert_eq "created finish-force worktree" "$WT_FORCE" "$stdout_force"
echo "force-work" > "${WT_FORCE}/force-work.txt"
git -C "$WT_FORCE" add force-work.txt
git -C "$WT_FORCE" commit -q -m "force finish test commit"
# Mock gh to return OPEN
MOCK_BIN_FORCE="${TMPROOT}/mock-bin-force"
mkdir -p "$MOCK_BIN_FORCE"
cat > "${MOCK_BIN_FORCE}/gh" << 'MOCKEOF_FORCE'
#!/usr/bin/env bash
if [[ "$1" == "pr" && "$2" == "view" ]]; then
  echo "OPEN"
fi
MOCKEOF_FORCE
chmod +x "${MOCK_BIN_FORCE}/gh"
git -C "$REPO" checkout -q main
cd "$WT_FORCE"
_tmp_force=$(mktemp)
stdout_fin_force=$(PATH="${MOCK_BIN_FORCE}:${PATH}" WT_REGISTRY="$registry_file" bash "$WT" finish --force --yes 2>"$_tmp_force") || true
out_fin_force=$(cat "$_tmp_force"); rm -f "$_tmp_force"
assert_contains "finish --force bypasses PR-open block" "Done!" "$out_fin_force"
assert_eq "stdout is main path" "$REPO" "$stdout_fin_force"
assert_dir_not_exists "worktree removed" "$WT_FORCE"
branch_force=$(git -C "$REPO" rev-parse --verify "wt/finish-force-test" 2>/dev/null || echo "gone")
assert_eq "branch deleted" "gone" "$branch_force"
rm -rf "$MOCK_BIN_FORCE"

# ─── S3: fast-forward when third worktree holds base_branch ──────────────────

section "S3: wt finish — succeeds when third worktree has base checked out"
# Setup:
#   Main WT      → main
#   WT_S3A       → dev (the base branch) checked out there
#   WT_S3B       → wt/s3-finisher (1 commit ahead of dev), base_branch=dev
# Without the fix, git fetch . HEAD:dev fails (dev locked by WT_S3A) and
# fallback also fails (main WT is on main, not dev) → manual instructions shown.
cd "$REPO"
git -C "$REPO" checkout -q main   # main WT now on main; dev is free
WT_S3A="${REPO}/.worktrees/s3-holder"
WT_S3B="${REPO}/.worktrees/s3-finisher"
# Create s3-holder as a bare worktree, then check out dev in it (dev is free now)
git -C "$REPO" worktree add "$WT_S3A" -b wt/s3-holder >/dev/null 2>&1
git -C "$WT_S3A" checkout -q dev   # dev is now locked by WT_S3A
# Create s3-finisher from dev HEAD
git -C "$REPO" worktree add "$WT_S3B" -b wt/s3-finisher dev >/dev/null 2>&1
# Write .wt-meta manually (can't use wt new since main WT is on main)
cat > "${WT_S3B}/.wt-meta" <<S3META
base_branch=dev
branch=wt/s3-finisher
slug=s3-finisher
description=s3 finisher
project=test-project
project_root=${REPO}
created=$(date '+%Y-%m-%dT%H:%M:%S')
S3META
# Register project in registry (may already be there)
grep -qxF "$REPO" "$registry_file" 2>/dev/null || echo "$REPO" >> "$registry_file"
# Add one commit to s3-finisher
echo "s3-work" > "${WT_S3B}/s3-work.txt"
git -C "$WT_S3B" add s3-work.txt
git -C "$WT_S3B" commit -q -m "s3 finisher work"
# Now: main=main, s3-holder=dev (locked!), s3-finisher=wt/s3-finisher ahead of dev
cd "$WT_S3B"
_tmp_s3=$(mktemp)
stdout_s3=$(WT_REGISTRY="$registry_file" bash "$WT" finish --yes 2>"$_tmp_s3") || true
out_s3=$(cat "$_tmp_s3"); rm -f "$_tmp_s3"
assert_contains "finish succeeds despite third worktree holding base" "Done!" "$out_s3"
assert_dir_not_exists "finisher worktree removed" "$WT_S3B"
branch_s3=$(git -C "$REPO" rev-parse --verify "wt/s3-finisher" 2>/dev/null || echo "gone")
assert_eq "finisher branch deleted" "gone" "$branch_s3"
# Verify the commit landed on dev
dev_log_s3=$(git -C "$WT_S3A" log --oneline -5 2>/dev/null || true)
assert_contains "s3 commit landed on dev" "s3 finisher work" "$dev_log_s3"
# Cleanup holder
cd "$REPO"
git -C "$REPO" worktree remove "$WT_S3A" --force 2>/dev/null || true
git -C "$REPO" branch -D "wt/s3-holder" 2>/dev/null || true

# ─── S4: wt finish — local base ahead of origin ──────────────────────────────

section "S4: wt finish — succeeds when local base is ahead of origin"
# Scenario: two worktrees created in parallel from the same dev base (X).
# First finishes → local dev advances to X→A (not pushed, origin stays at X).
# Second then finishes: its branch is based on X (old dev), rebasing onto
# origin/dev (X) is a no-op, but fast-forward from local dev (X→A) fails
# because A is not in the feature branch's ancestry. Fix: rebase onto local
# dev when it's ahead, so feature becomes X→A→B' and ff works.
cd "$REPO"
git -C "$REPO" checkout -q dev

BARE_S4="${TMPROOT}/bare-s4.git"
git -C "$REPO" clone --bare . "$BARE_S4" 2>/dev/null
git -C "$REPO" remote add origin "$BARE_S4" 2>/dev/null \
  || git -C "$REPO" remote set-url origin "$BARE_S4"
git -C "$REPO" fetch origin dev 2>/dev/null

# Create BOTH worktrees from the same dev base (parallel workflow)
WT_S4A="${REPO}/.worktrees/s4-first"
WT_S4B="${REPO}/.worktrees/s4-second"
WT_REGISTRY="$registry_file" bash "$WT" new "s4 first"  >/dev/null 2>&1
WT_REGISTRY="$registry_file" bash "$WT" new "s4 second" >/dev/null 2>&1

echo "s4-first-work" > "${WT_S4A}/s4-first.txt"
git -C "$WT_S4A" add s4-first.txt
git -C "$WT_S4A" commit -q -m "s4 first commit"

echo "s4-second-work" > "${WT_S4B}/s4-second.txt"
git -C "$WT_S4B" add s4-second.txt
git -C "$WT_S4B" commit -q -m "s4 second commit"

# Finish first — local dev advances to X→A; origin/dev stays at X
cd "$WT_S4A"
WT_REGISTRY="$registry_file" bash "$WT" finish --yes >/dev/null 2>&1
cd "$REPO"

# Precondition: origin/dev doesn't have first commit; local dev does
origin_log_s4=$(git -C "$REPO" log origin/dev --oneline 2>/dev/null || true)
assert_not_contains "S4 precondition: origin/dev lacks first commit" \
  "s4 first commit" "$origin_log_s4"

# Now finish second — branch is still based on X (not X→A), so after rebasing
# onto origin/dev (X) the feature tip is X→B; local dev is X→A; X→A is NOT
# an ancestor of X→B → ff fails without the fix
cd "$WT_S4B"
_tmp_s4=$(mktemp)
stdout_s4b=$(WT_REGISTRY="$registry_file" bash "$WT" finish --yes 2>"$_tmp_s4") || true
out_s4b=$(cat "$_tmp_s4"); rm -f "$_tmp_s4"

assert_contains "S4 second finish succeeds despite local base ahead of origin" "Done!" "$out_s4b"
assert_dir_not_exists "S4 second worktree removed" "$WT_S4B"
branch_s4b=$(git -C "$REPO" rev-parse --verify "wt/s4-second" 2>/dev/null || echo "gone")
assert_eq "S4 second branch deleted" "gone" "$branch_s4b"
cd "$REPO"
dev_log_s4=$(git -C "$REPO" log --oneline -5)
assert_contains "S4 first commit landed on dev"  "s4 first commit"  "$dev_log_s4"
assert_contains "S4 second commit landed on dev" "s4 second commit" "$dev_log_s4"

# Cleanup
git -C "$REPO" remote remove origin 2>/dev/null || true
rm -rf "$BARE_S4"

# ─── S5: wt sync — local base ahead of origin ────────────────────────────────

section "S5: wt sync — rebases onto local base when ahead of origin"
# Same parallel setup: two worktrees from X. First finishes (local dev → X→A,
# origin stays at X). wt sync on second should rebase onto local dev (X→A),
# not stale origin/dev (X), so the synced branch includes A.
cd "$REPO"
git -C "$REPO" checkout -q dev

BARE_S5="${TMPROOT}/bare-s5.git"
git -C "$REPO" clone --bare . "$BARE_S5" 2>/dev/null
git -C "$REPO" remote add origin "$BARE_S5" 2>/dev/null \
  || git -C "$REPO" remote set-url origin "$BARE_S5"
git -C "$REPO" fetch origin dev 2>/dev/null

WT_S5A="${REPO}/.worktrees/s5-first"
WT_S5B="${REPO}/.worktrees/s5-second"
WT_REGISTRY="$registry_file" bash "$WT" new "s5 first"  >/dev/null 2>&1
WT_REGISTRY="$registry_file" bash "$WT" new "s5 second" >/dev/null 2>&1

echo "s5-first-work" > "${WT_S5A}/s5-first.txt"
git -C "$WT_S5A" add s5-first.txt
git -C "$WT_S5A" commit -q -m "s5 first commit"

echo "s5-second-work" > "${WT_S5B}/s5-second.txt"
git -C "$WT_S5B" add s5-second.txt
git -C "$WT_S5B" commit -q -m "s5 second commit"

# Finish first — local dev advances to X→A; origin/dev stays at X
cd "$WT_S5A"
WT_REGISTRY="$registry_file" bash "$WT" finish --yes >/dev/null 2>&1
cd "$REPO"

# Sync second — should rebase onto local dev (X→A), not origin/dev (X)
cd "$WT_S5B"
_tmp_s5=$(mktemp)
WT_REGISTRY="$registry_file" bash "$WT" sync 2>"$_tmp_s5" || true
out_s5=$(cat "$_tmp_s5"); rm -f "$_tmp_s5"

assert_contains "S5 sync succeeds" "Synced" "$out_s5"
# The synced branch must include s5 first commit (from local dev) in its log
branch_log_s5=$(git -C "$WT_S5B" log --oneline 2>/dev/null || true)
assert_contains "S5 synced branch includes first commit" "s5 first commit" "$branch_log_s5"

# Cleanup
cd "$REPO"
git -C "$REPO" worktree remove "$WT_S5B" --force 2>/dev/null || true
git -C "$REPO" branch -D "wt/s5-second" 2>/dev/null || true
git -C "$REPO" remote remove origin 2>/dev/null || true
rm -rf "$BARE_S5"

# ─── M1: slugify strips leading hyphens ──────────────────────────────────────

section "M1: slugify — leading hyphens stripped from slug"
cd "$REPO"
git -C "$REPO" checkout -q dev
# Description starting with hyphens should produce a slug without leading hyphens
# Two leading spaces → after slugify → "-verbose-mode" (pre-fix) or "verbose-mode" (post-fix)
stdout_slug=$(WT_REGISTRY="$registry_file" bash "$WT" new "  verbose mode" 2>/dev/null) || true
WT_SLUG="${REPO}/.worktrees/verbose-mode"
assert_eq "stdout is correct path (no leading hyphens)" "$WT_SLUG" "$stdout_slug"
assert_dir_exists "worktree created at correct path" "$WT_SLUG"
slug_val=$(grep "^slug=" "${WT_SLUG}/.wt-meta" 2>/dev/null | cut -d= -f2- || true)
assert_eq "slug has no leading hyphens" "verbose-mode" "$slug_val"
branch_val=$(grep "^branch=" "${WT_SLUG}/.wt-meta" 2>/dev/null | cut -d= -f2- || true)
assert_eq "branch has no leading hyphens" "wt/verbose-mode" "$branch_val"
git -C "$REPO" worktree remove "$WT_SLUG" --force 2>/dev/null || true
git -C "$REPO" branch -D "wt/verbose-mode" 2>/dev/null || true

# ─── M2: doctor uses fixed-string grep for worktree paths ────────────────────

section "M2: wt doctor — handles paths with BRE regex metacharacters (brackets in path)"
REGEX_BASE="${TMPROOT}/my[proj]"   # brackets are BRE metachar — break grep character class
REGEX_REG="${TMPROOT}/regex-registry"  # isolated registry for this test
mkdir -p "$REGEX_BASE"
git -C "$REGEX_BASE" init -q -b main
git -C "$REGEX_BASE" config user.email "test@test.com"
git -C "$REGEX_BASE" config user.name "Test"
echo "init" > "$REGEX_BASE/README.md"
git -C "$REGEX_BASE" add README.md
git -C "$REGEX_BASE" commit -q -m "initial"
cd "$REGEX_BASE"
WT_REGEX="${REGEX_BASE}/.worktrees/regex-test"
WT_REGISTRY="$REGEX_REG" bash "$WT" new "regex test" 2>/dev/null
cd "$WT_REGEX"
echo "work" > work.txt
git -C "$WT_REGEX" add work.txt
git -C "$WT_REGEX" commit -q -m "work"
cd "$REGEX_BASE"
_tmp_m2=$(mktemp)
# Use isolated registry containing ONLY regex+proj so "all good" can only come from it
WT_REGISTRY="$REGEX_REG" bash "$WT" doctor > "$_tmp_m2" 2>&1 < /dev/null || true
out_m2=$(cat "$_tmp_m2"); rm -f "$_tmp_m2"
# doctor should report "all good" — brackets must not cause false negative (orphan false alarm)
assert_contains "doctor passes for path with brackets" "all good" "$out_m2"
# Cleanup
git -C "$REGEX_BASE" worktree remove "$WT_REGEX" --force 2>/dev/null || true
git -C "$REGEX_BASE" branch -D "wt/regex-test" 2>/dev/null || true

# ─── M4: retarget picker excludes current worktree branch ────────────────────

section "M4: wt retarget — interactive picker excludes current worktree branch (wt/slug)"
RT_PROJ="${TMPROOT}/rt-excl-proj"
mkdir -p "$RT_PROJ"
git -C "$RT_PROJ" init -q -b main
git -C "$RT_PROJ" config user.email "test@test.com"
git -C "$RT_PROJ" config user.name "Test"
echo "init" > "$RT_PROJ/README.md"
git -C "$RT_PROJ" add README.md
git -C "$RT_PROJ" commit -q -m "initial"
git -C "$RT_PROJ" checkout -q -b dev
echo "dev" > "$RT_PROJ/dev.txt"
git -C "$RT_PROJ" add dev.txt
git -C "$RT_PROJ" commit -q -m "dev commit"
git -C "$RT_PROJ" checkout -q main
cd "$RT_PROJ"
# Branch will be wt/excl-test; local branches: main, dev, wt/excl-test
RT_WT="${RT_PROJ}/.worktrees/excl-test"
WT_REGISTRY="$registry_file" bash "$WT" new "excl test" 2>/dev/null
cd "$RT_WT"
# Feed invalid choice — causes picker to print list then abort
out_rt_excl=$(printf "99\n" | WT_REGISTRY="$registry_file" bash "$WT" retarget 2>&1) || true
# wt/excl-test is the current branch — must NOT appear in the picker list
assert_not_contains "picker excludes current wt/slug branch" "wt/excl-test" "$out_rt_excl"
# dev and main must appear (the valid targets)
assert_contains     "picker shows other local branches"     "dev"          "$out_rt_excl"
cd "$RT_PROJ"
git -C "$RT_PROJ" worktree remove "$RT_WT" --force 2>/dev/null || true
git -C "$RT_PROJ" branch -D "wt/excl-test" 2>/dev/null || true

# ─── M4: cmd_pr picker — no remote branches shows single warning ──────────────

section "M4: wt pr — no remote branches shows exactly one warning (not double)"
M4_PROJ="${TMPROOT}/m4-proj"
mkdir -p "$M4_PROJ"
git -C "$M4_PROJ" init -q -b main
git -C "$M4_PROJ" config user.email "test@test.com"
git -C "$M4_PROJ" config user.name "Test"
echo "init" > "$M4_PROJ/README.md"
git -C "$M4_PROJ" add README.md
git -C "$M4_PROJ" commit -q -m "initial"
# Empty bare remote — has no branches so the remote branch list will be empty
M4_BARE="${TMPROOT}/m4-bare.git"
git init --bare -q "$M4_BARE"
cd "$M4_PROJ"
M4_WT="${M4_PROJ}/.worktrees/m4-picker-test"
WT_REGISTRY="$registry_file" bash "$WT" new "m4 picker test" 2>/dev/null
echo "work" > "${M4_WT}/work.txt"
git -C "$M4_WT" add work.txt
git -C "$M4_WT" commit -q -m "m4 work"
git -C "$M4_WT" remote add origin "file://${M4_BARE}"
M4_MOCK="${TMPROOT}/m4-mock-bin"
mkdir -p "$M4_MOCK"
# gh: no existing PR on view, return a URL on create
cat > "${M4_MOCK}/gh" << 'M4_MOCKEOF'
#!/usr/bin/env bash
if [[ "$1" == "pr" && "$2" == "view" ]]; then exit 1; fi
if [[ "$1" == "pr" && "$2" == "create" ]]; then echo "https://github.com/test/pr/1"; fi
M4_MOCKEOF
chmod +x "${M4_MOCK}/gh"
cd "$M4_WT"
# Answer 'y' to "change base?" — picker finds no remote branches, should warn once
out_m4=$(printf 'y\n' | PATH="${M4_MOCK}:${PATH}" WT_REGISTRY="$registry_file" bash "$WT" pr 2>&1 || true)
assert_contains     "shows no-remote-branches warning" "No remote branches found" "$out_m4"
assert_not_contains "does not also show invalid-choice" "Invalid choice"          "$out_m4"
cd "$M4_PROJ"
git -C "$M4_PROJ" worktree remove "$M4_WT" --force 2>/dev/null || true
git -C "$M4_PROJ" branch -D "wt/m4-picker-test" 2>/dev/null || true
rm -rf "$M4_MOCK" "$M4_BARE"

