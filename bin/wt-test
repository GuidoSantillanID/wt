out_t3d=$(cat "$_tmp_t3d"); rm -f "$_tmp_t3d"
assert_contains "abandon --yes with 0 ahead succeeds" "Dropped" "$out_t3d"
assert_dir_not_exists "worktree removed" "$WT_T3D"

# ─── Chunk 4: wt finish — non-skippable untracked + --force ──────────────────

section "T4b: wt finish --force --yes — untracked files: force overrides gate"
cd "$REPO"
git -C "$REPO" checkout -q dev
WT_T4B="${REPO}/.worktrees/t4b-test"
WT_REGISTRY="$registry_file" bash "$WT" new "t4b test" 2>/dev/null
