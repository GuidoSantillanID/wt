# ─── wt pr ───────────────────────────────────────────────────────────────────

section "wt pr — error when run from main checkout"
cd "$REPO"
out=$(wt pr 2>&1 || true)
assert_contains "errors when not in a worktree" "main checkout" "$out"

section "wt pr — error when gh not installed"
cd "$REPO"
git -C "$REPO" checkout -q dev
WT_PATH_PR="${REPO}/.worktrees/pr-test"
wt new "pr test" 2>/dev/null
echo "work" > "${WT_PATH_PR}/work.txt"
git -C "$WT_PATH_PR" add work.txt
git -C "$WT_PATH_PR" commit -q -m "pr test commit"
cd "$WT_PATH_PR"
_gh_env=$(mktemp)
printf 'command() { [[ "$1 $2" == "-v gh" ]] && return 1; builtin command "$@"; }\n' > "$_gh_env"
out=$(BASH_ENV="$_gh_env" WT_REGISTRY="$registry_file" bash "$WT" pr 2>&1 || true)
rm -f "$_gh_env"
assert_contains "errors without gh" "gh CLI required" "$out"

section "wt pr — blocks on dirty worktree"
cd "$WT_PATH_PR"
