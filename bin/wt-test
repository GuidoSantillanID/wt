# ─── S4: wt retarget interactive picker exits cleanly on EOF ──────────────────

section "S4: wt retarget — interactive picker exits cleanly on EOF (stdin closed)"
S4_PROJ="${TMPROOT}/s4-proj"
mkdir -p "$S4_PROJ"
git -C "$S4_PROJ" init -q -b main
git -C "$S4_PROJ" config user.email "test@test.com"
git -C "$S4_PROJ" config user.name "Test"
echo "init" > "$S4_PROJ/README.md"
git -C "$S4_PROJ" add README.md
git -C "$S4_PROJ" commit -q -m "initial"
git -C "$S4_PROJ" checkout -q -b dev
echo "dev" > "$S4_PROJ/dev.txt"
git -C "$S4_PROJ" add dev.txt
git -C "$S4_PROJ" commit -q -m "dev commit"
git -C "$S4_PROJ" checkout -q main
cd "$S4_PROJ"
S4_WT="${S4_PROJ}/.worktrees/s4-test"
WT_REGISTRY="$registry_file" bash "$WT" new "s4 test" 2>/dev/null
cd "$S4_WT"
# Run retarget with no args (interactive picker) and stdin closed — must not crash
s4_exit=0
