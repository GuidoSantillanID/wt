assert_eq "slug has no leading hyphens" "verbose-mode" "$slug_val"
branch_val=$(grep "^branch=" "${WT_SLUG}/.wt-meta" 2>/dev/null | cut -d= -f2- || true)
assert_eq "branch has no leading hyphens" "wt/verbose-mode" "$branch_val"
git -C "$REPO" worktree remove "$WT_SLUG" --force 2>/dev/null || true
git -C "$REPO" branch -D "wt/verbose-mode" 2>/dev/null || true

# ─── M2: doctor uses fixed-string grep for worktree paths ────────────────────

section "M2: wt doctor — handles paths with BRE regex metacharacters (brackets in path)"
REGEX_BASE="${TMPROOT}/my[proj]"   # brackets are BRE metachar — break grep character class
REGEX_REG="${TMPROOT}/regex-registry"  # isolated registry for this test
mkdir -p "$REGEX_BASE"
git -C "$REGEX_BASE" init -q -b main
git -C "$REGEX_BASE" config user.email "test@test.com"
git -C "$REGEX_BASE" config user.name "Test"
echo "init" > "$REGEX_BASE/README.md"
git -C "$REGEX_BASE" add README.md
git -C "$REGEX_BASE" commit -q -m "initial"
cd "$REGEX_BASE"
WT_REGEX="${REGEX_BASE}/.worktrees/regex-test"
WT_REGISTRY="$REGEX_REG" bash "$WT" new "regex test" 2>/dev/null
cd "$WT_REGEX"
echo "work" > work.txt
git -C "$WT_REGEX" add work.txt
git -C "$WT_REGEX" commit -q -m "work"
cd "$REGEX_BASE"
_tmp_m2=$(mktemp)
# Use isolated registry containing ONLY regex+proj so "all good" can only come from it
WT_REGISTRY="$REGEX_REG" bash "$WT" doctor > "$_tmp_m2" 2>&1 < /dev/null || true
out_m2=$(cat "$_tmp_m2"); rm -f "$_tmp_m2"
# doctor should report "all good" — brackets must not cause false negative (orphan false alarm)
assert_contains "doctor passes for path with brackets" "all good" "$out_m2"
# Cleanup
git -C "$REGEX_BASE" worktree remove "$WT_REGEX" --force 2>/dev/null || true
git -C "$REGEX_BASE" branch -D "wt/regex-test" 2>/dev/null || true

