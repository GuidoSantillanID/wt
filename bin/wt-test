assert_contains "blocks on uncommitted changes" "Uncommitted changes" "$out"
rm dirty-pr.txt

section "wt pr — unknown flag error"
cd "$WT_PATH_PR"
out=$(wt pr --foo 2>&1 || true)
assert_contains "unknown flag error" "Unknown flag" "$out"

section "wt pr — creates PR with mock gh and bare remote"
MOCK_BIN="${TMPROOT}/mock-bin"
mkdir -p "$MOCK_BIN"
cat > "${MOCK_BIN}/gh" << 'MOCKEOF'
#!/usr/bin/env bash
echo "$@" >> "${MOCK_BIN}/gh-calls.log"
if [[ "$1" == "pr" && "$2" == "view" ]]; then
  exit 1
elif [[ "$1" == "pr" && "$2" == "create" ]]; then
  echo "https://github.com/test/test/pull/42"
fi
MOCKEOF
# Fix: MOCK_BIN variable isn't expanded in heredoc — embed path explicitly
sed -i.bak "s|\${MOCK_BIN}|${MOCK_BIN}|g" "${MOCK_BIN}/gh" && rm "${MOCK_BIN}/gh.bak"
chmod +x "${MOCK_BIN}/gh"

BARE="${TMPROOT}/bare-remote.git"
git -C "$REPO" clone --bare . "$BARE" 2>/dev/null
git -C "$WT_PATH_PR" remote add origin "$BARE"

cd "$WT_PATH_PR"
_tmp_pr=$(mktemp)
stdout_pr=$(PATH="${MOCK_BIN}:${PATH}" WT_REGISTRY="$registry_file" bash "$WT" pr --yes 2>"$_tmp_pr")
out_pr=$(cat "$_tmp_pr"); rm -f "$_tmp_pr"
assert_contains "PR URL on stdout"   "https://github.com"  "$stdout_pr"
assert_contains "reports PR created" "PR created"          "$out_pr"
gh_log=$(cat "${MOCK_BIN}/gh-calls.log" 2>/dev/null || echo "")
assert_contains "gh pr create called"  "pr create"           "$gh_log"
assert_contains "base branch passed"   "--base dev"          "$gh_log"
assert_contains "title passed"         "--title pr test"     "$gh_log"
assert_contains "body from commits"    "pr test commit"      "$gh_log"

section "wt pr --draft — passes draft flag to gh"
rm -f "${MOCK_BIN}/gh-calls.log"
cd "$WT_PATH_PR"
PATH="${MOCK_BIN}:${PATH}" WT_REGISTRY="$registry_file" bash "$WT" pr --draft --yes 2>/dev/null || true
gh_log=$(cat "${MOCK_BIN}/gh-calls.log" 2>/dev/null || echo "")
assert_contains "draft flag passed" "--draft" "$gh_log"

section "wt pr — existing PR detected"
cat > "${MOCK_BIN}/gh" << 'MOCKEOF2'
#!/usr/bin/env bash
if [[ "$1" == "pr" && "$2" == "view" ]]; then
  echo "https://github.com/test/test/pull/42"
fi
MOCKEOF2
chmod +x "${MOCK_BIN}/gh"
cd "$WT_PATH_PR"
_tmp_pr2=$(mktemp)
stdout_pr2=$(PATH="${MOCK_BIN}:${PATH}" WT_REGISTRY="$registry_file" bash "$WT" pr --yes 2>"$_tmp_pr2")
out_pr2=$(cat "$_tmp_pr2"); rm -f "$_tmp_pr2"
assert_contains "shows existing PR URL" "https://github.com" "$stdout_pr2"
assert_contains "reports already exists" "already exists"    "$out_pr2"

git -C "$REPO" worktree remove "$WT_PATH_PR" --force 2>/dev/null || true
git -C "$REPO" branch -D "wt/pr-test" 2>/dev/null || true
rm -rf "$MOCK_BIN" "$BARE"

# ─── wt pr — base branch selection ───────────────────────────────────────────

section "wt pr — change base branch interactively"
cd "$REPO"
git -C "$REPO" checkout -q dev
# Create extra branches on origin so the list is non-empty
BARE2="${TMPROOT}/bare-remote2.git"
git -C "$REPO" clone --bare . "$BARE2" 2>/dev/null
# Add a second branch to the bare remote
git -C "$REPO" push "$BARE2" dev:feature-x 2>/dev/null || true

WT_PATH_BASE="${REPO}/.worktrees/base-change-test"
wt new "base change test" 2>/dev/null
echo "work" > "${WT_PATH_BASE}/work.txt"
git -C "$WT_PATH_BASE" add work.txt
git -C "$WT_PATH_BASE" commit -q -m "base change test commit"
git -C "$WT_PATH_BASE" remote set-url origin "$BARE2"
git -C "$WT_PATH_BASE" fetch origin 2>/dev/null

MOCK_BIN2="${TMPROOT}/mock-bin2"
mkdir -p "$MOCK_BIN2"
cat > "${MOCK_BIN2}/gh" << 'MOCKEOF3'
#!/usr/bin/env bash
echo "$@" >> "${MOCK_BIN2_PATH}/gh-calls.log"
if [[ "$1" == "pr" && "$2" == "view" ]]; then
  exit 1
elif [[ "$1" == "pr" && "$2" == "create" ]]; then
  echo "https://github.com/test/test/pull/99"
fi
MOCKEOF3
sed -i.bak "s|\${MOCK_BIN2_PATH}|${MOCK_BIN2}|g" "${MOCK_BIN2}/gh" && rm "${MOCK_BIN2}/gh.bak"
chmod +x "${MOCK_BIN2}/gh"

cd "$WT_PATH_BASE"
# Input: "y" to change base, then pick "2" (feature-x, sorted after dev), then "y" to confirm PR
_tmp_base=$(mktemp)
stdout_base=$(printf 'y\n2\ny\n' | PATH="${MOCK_BIN2}:${PATH}" WT_REGISTRY="$registry_file" bash "$WT" pr 2>"$_tmp_base" || true)
out_base=$(cat "$_tmp_base"); rm -f "$_tmp_base"
gh_log2=$(cat "${MOCK_BIN2}/gh-calls.log" 2>/dev/null || echo "")
assert_contains "base changed in gh call"  "--base feature-x"   "$gh_log2"
# Verify .wt-meta was updated
meta_val=$(grep "^base_branch=" "${WT_PATH_BASE}/.wt-meta" | cut -d= -f2)
assert_eq "wt-meta updated with new base" "feature-x" "$meta_val"

section "wt pr --yes — skips base branch prompt"
rm -f "${MOCK_BIN2}/gh-calls.log"
cd "$WT_PATH_BASE"
# Reset .wt-meta base back to dev
sed -i.bak "s/^base_branch=.*/base_branch=dev/" "${WT_PATH_BASE}/.wt-meta" && rm -f "${WT_PATH_BASE}/.wt-meta.bak"
_tmp_yes=$(mktemp)
PATH="${MOCK_BIN2}:${PATH}" WT_REGISTRY="$registry_file" bash "$WT" pr --yes 2>"$_tmp_yes" || true
out_yes=$(cat "$_tmp_yes"); rm -f "$_tmp_yes"
assert_not_contains "no change-base prompt with --yes" "change?" "$out_yes"
gh_log3=$(cat "${MOCK_BIN2}/gh-calls.log" 2>/dev/null || echo "")
assert_contains "uses original base with --yes" "--base dev" "$gh_log3"

git -C "$REPO" worktree remove "$WT_PATH_BASE" --force 2>/dev/null || true
git -C "$REPO" branch -D "wt/base-change-test" 2>/dev/null || true
rm -rf "$MOCK_BIN2" "$BARE2"

# ─── registry ────────────────────────────────────────────────────────────────

section "registry — project registered after wt new"
# REPO was registered by the very first wt new call above
assert_contains "registry contains REPO" "$REPO" "$(cat "$registry_file" 2>/dev/null)"

section "registry — wt new with two args errors"
cd "$REPO"
out=$(wt new "project-name" "desc" 2>&1 || true)
assert_contains "two-arg form errors" "Usage:" "$out"

# Use a fresh isolated project to test unregister behavior
REG_PROJ="${TMPROOT}/reg-proj"
mkdir -p "$REG_PROJ"
git -C "$REG_PROJ" init -q
git -C "$REG_PROJ" config user.email "test@test.com"
git -C "$REG_PROJ" config user.name "Test"
echo "init" > "$REG_PROJ/README.md"
git -C "$REG_PROJ" add README.md
git -C "$REG_PROJ" commit -q -m "init"

section "registry — project unregistered after wt abandon (no branches remain)"
cd "$REG_PROJ"
wt new "drop-cleanup" 2>/dev/null
assert_contains "registry has reg-proj after new" "$REG_PROJ" "$(cat "$registry_file")"
cd "$REG_PROJ/.worktrees/drop-cleanup"
wt abandon --yes 2>/dev/null
assert_not_contains "registry cleared after last abandon" "$REG_PROJ" "$(cat "$registry_file" 2>/dev/null)"

section "registry — project unregistered after wt finish (no branches remain)"
cd "$REG_PROJ"
wt new "finish-cleanup" 2>/dev/null
REG_FINISH="${REG_PROJ}/.worktrees/finish-cleanup"
echo "work" > "${REG_FINISH}/work.txt"
git -C "$REG_FINISH" add work.txt
git -C "$REG_FINISH" commit -q -m "finish cleanup test"
cd "$REG_FINISH"
wt finish --yes 2>/dev/null
assert_not_contains "registry cleared after last finish" "$REG_PROJ" "$(cat "$registry_file" 2>/dev/null)"

section "registry — project NOT unregistered if wt/* branches remain"
cd "$REG_PROJ"
wt new "orphan-test" 2>/dev/null
# Create an orphaned wt/* branch manually (no worktree dir)
git -C "$REG_PROJ" branch wt/orphan-stays
cd "$REG_PROJ/.worktrees/orphan-test"
wt abandon --yes 2>/dev/null  # .worktrees/ empty, but wt/orphan-stays still exists
assert_contains "registry preserved when branches remain" "$REG_PROJ" "$(cat "$registry_file" 2>/dev/null)"
# Clean up the orphaned branch
git -C "$REG_PROJ" branch -D wt/orphan-stays 2>/dev/null

section "registry — auto-unregister fires when both conditions met"
# REG_PROJ is still registered (orphan-stays prevented unregister above)
cd "$REG_PROJ"
wt new "final-cleanup" 2>/dev/null
cd "$REG_PROJ/.worktrees/final-cleanup"
wt abandon --yes 2>/dev/null  # empty .worktrees/ + no wt/* branches now
assert_not_contains "auto-unregister fired" "$REG_PROJ" "$(cat "$registry_file" 2>/dev/null)"

# ─── wt retarget ─────────────────────────────────────────────────────────────

# Setup: fresh project with two local branches (main, feature-a) for retarget tests
RETARGET_PROJ="${TMPROOT}/retarget-proj"
mkdir -p "$RETARGET_PROJ"
git -C "$RETARGET_PROJ" init -q
git -C "$RETARGET_PROJ" config user.email "test@test.com"
git -C "$RETARGET_PROJ" config user.name "Test"
echo "init" > "$RETARGET_PROJ/README.md"
git -C "$RETARGET_PROJ" add README.md
git -C "$RETARGET_PROJ" commit -q -m "initial"
# Create a second local branch to retarget onto
git -C "$RETARGET_PROJ" checkout -q -b feature-a
echo "feature-a" > "$RETARGET_PROJ/feature-a.txt"
git -C "$RETARGET_PROJ" add feature-a.txt
git -C "$RETARGET_PROJ" commit -q -m "feature-a commit"
git -C "$RETARGET_PROJ" checkout -q main

cd "$RETARGET_PROJ"
WT_RETARGET="${RETARGET_PROJ}/.worktrees/retarget-test"
wt new "retarget test" 2>/dev/null

section "wt retarget — change base with argument"
cd "$WT_RETARGET"
out_ret=$(wt retarget feature-a 2>&1 || true)
meta_base=$(grep "^base_branch=" "${WT_RETARGET}/.wt-meta" | cut -d= -f2)
assert_eq       ".wt-meta base_branch updated" "feature-a" "$meta_base"
assert_contains "success message shown"        "feature-a" "$out_ret"

section "wt retarget — no stdout output (no cd contract)"
cd "$WT_RETARGET"
# Reset to main first
sed -i.bak "s/^base_branch=.*/base_branch=main/" "${WT_RETARGET}/.wt-meta" && rm -f "${WT_RETARGET}/.wt-meta.bak"
stdout_ret=$(wt retarget feature-a 2>/dev/null || true)
assert_eq "stdout is empty" "" "$stdout_ret"

section "wt retarget — same base is a no-op"
cd "$WT_RETARGET"
out_noop=$(wt retarget feature-a 2>&1 || true)
assert_contains "reports already targeting" "feature-a" "$out_noop"
# base_branch should still be feature-a (no change)
meta_base2=$(grep "^base_branch=" "${WT_RETARGET}/.wt-meta" | cut -d= -f2)
assert_eq ".wt-meta unchanged" "feature-a" "$meta_base2"

section "wt retarget — invalid branch errors"
cd "$WT_RETARGET"
out_inv=$(wt retarget nonexistent-branch-xyz 2>&1 || true)
assert_contains "errors on unknown branch" "nonexistent-branch-xyz" "$out_inv"

section "wt retarget — from main checkout errors"
cd "$RETARGET_PROJ"
out_main=$(wt retarget feature-a 2>&1 || true)
assert_contains "errors outside worktree" "main checkout" "$out_main"

section "wt retarget — missing .wt-meta errors"
# Create a bare worktree dir without .wt-meta
NO_META_WT="${RETARGET_PROJ}/.worktrees/no-meta-test"
git -C "$RETARGET_PROJ" worktree add "$NO_META_WT" -b wt/no-meta-test 2>/dev/null
cd "$NO_META_WT"
out_nometa=$(WT_REGISTRY="$registry_file" bash "$WT" retarget feature-a 2>&1 || true)
assert_contains "errors on missing .wt-meta" ".wt-meta" "$out_nometa"
git -C "$RETARGET_PROJ" worktree remove "$NO_META_WT" --force 2>/dev/null || true
git -C "$RETARGET_PROJ" branch -D wt/no-meta-test 2>/dev/null || true

# Cleanup retarget project
git -C "$RETARGET_PROJ" worktree remove "$WT_RETARGET" --force 2>/dev/null || true
git -C "$RETARGET_PROJ" branch -D wt/retarget-test 2>/dev/null || true

# ─── C1: get_main_worktree with spaces in path ───────────────────────────────

section "C1: get_main_worktree — path with spaces in directory name"
