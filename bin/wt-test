git -C "$SLASH_PROJ" branch -D "wt/slash-test" 2>/dev/null || true

# ─── C3: finish warns before destroying untracked files ──────────────────────

section "C3: wt finish — warns when untracked files present (confirms before --force)"
cd "$REPO"
git -C "$REPO" checkout -q dev
WT_UNTRACKED="${REPO}/.worktrees/untracked-finish-test"
WT_REGISTRY="$registry_file" bash "$WT" new "untracked finish test" 2>/dev/null
echo "committed" > "${WT_UNTRACKED}/committed.txt"
git -C "$WT_UNTRACKED" add committed.txt
git -C "$WT_UNTRACKED" commit -q -m "committed work"
# Add an untracked file that would be silently destroyed by --force
echo "precious untracked data" > "${WT_UNTRACKED}/untracked.txt"
cd "$WT_UNTRACKED"
# Say "n" to the untracked-file warning — should abort
out_c3=$(printf "n\n" | WT_REGISTRY="$registry_file" bash "$WT" finish 2>&1) || true
assert_contains "warns about untracked files" "Untracked files" "$out_c3"
assert_dir_exists "worktree preserved when user declines" "$WT_UNTRACKED"
assert_file_exists "untracked file preserved" "${WT_UNTRACKED}/untracked.txt"
# Now say "y" to untracked warning — no strategy prompt, finishes directly
git -C "$REPO" checkout -q main
out_c3y=$(printf "y\n" | WT_REGISTRY="$registry_file" bash "$WT" finish 2>&1) || true
assert_contains "finish proceeds when user accepts" "Done!" "$out_c3y"
assert_dir_not_exists "worktree removed after accept" "$WT_UNTRACKED"

section "C3: wt finish --yes — untracked files block despite --yes (non-skippable)"
cd "$REPO"
git -C "$REPO" checkout -q dev
WT_UNTRACKED2="${REPO}/.worktrees/untracked-yes-test"
WT_REGISTRY="$registry_file" bash "$WT" new "untracked yes test" 2>/dev/null
echo "committed2" > "${WT_UNTRACKED2}/committed2.txt"
git -C "$WT_UNTRACKED2" add committed2.txt
git -C "$WT_UNTRACKED2" commit -q -m "committed work 2"
echo "untracked data" > "${WT_UNTRACKED2}/untracked2.txt"
cd "$WT_UNTRACKED2"
git -C "$REPO" checkout -q main
out_c3y2=$(WT_REGISTRY="$registry_file" bash "$WT" finish --yes 2>&1 < /dev/null) || true
assert_not_contains "finish --yes aborts with untracked (non-skippable)" "Done!" "$out_c3y2"
assert_dir_exists "worktree preserved when --yes cannot bypass gate" "$WT_UNTRACKED2"
# Cleanup preserved worktree
git -C "$REPO" worktree remove "$WT_UNTRACKED2" --force 2>/dev/null || true
git -C "$REPO" branch -D "wt/untracked-yes-test" 2>/dev/null || true

# ─── S2: wt finish --force skips PR-open block ───────────────────────────────

# S2 removed — finish no longer checks PR state

# ─── S3: fast-forward when third worktree holds base_branch ──────────────────

section "S3: wt finish — succeeds when third worktree has base checked out"
# Setup:
#   Main WT      → main
#   WT_S3A       → dev (the base branch) checked out there
#   WT_S3B       → wt/s3-finisher (1 commit ahead of dev), base_branch=dev
# Without the fix, git fetch . HEAD:dev fails (dev locked by WT_S3A) and
# fallback also fails (main WT is on main, not dev) → manual instructions shown.
cd "$REPO"
git -C "$REPO" checkout -q main   # main WT now on main; dev is free
WT_S3A="${REPO}/.worktrees/s3-holder"
WT_S3B="${REPO}/.worktrees/s3-finisher"
# Create s3-holder as a bare worktree, then check out dev in it (dev is free now)
git -C "$REPO" worktree add "$WT_S3A" -b wt/s3-holder >/dev/null 2>&1
git -C "$WT_S3A" checkout -q dev   # dev is now locked by WT_S3A
# Create s3-finisher from dev HEAD
git -C "$REPO" worktree add "$WT_S3B" -b wt/s3-finisher dev >/dev/null 2>&1
# Write .wt-meta manually (can't use wt new since main WT is on main)
cat > "${WT_S3B}/.wt-meta" <<S3META
base_branch=dev
branch=wt/s3-finisher
slug=s3-finisher
description=s3 finisher
project=test-project
project_root=${REPO}
created=$(date '+%Y-%m-%dT%H:%M:%S')
S3META
# Register project in registry (may already be there)
grep -qxF "$REPO" "$registry_file" 2>/dev/null || echo "$REPO" >> "$registry_file"
# Add one commit to s3-finisher
echo "s3-work" > "${WT_S3B}/s3-work.txt"
git -C "$WT_S3B" add s3-work.txt
git -C "$WT_S3B" commit -q -m "s3 finisher work"
# Now: main=main, s3-holder=dev (locked!), s3-finisher=wt/s3-finisher ahead of dev
cd "$WT_S3B"
_tmp_s3=$(mktemp)
stdout_s3=$(WT_REGISTRY="$registry_file" bash "$WT" finish --yes 2>"$_tmp_s3") || true
out_s3=$(cat "$_tmp_s3"); rm -f "$_tmp_s3"
assert_contains "finish succeeds despite third worktree holding base" "Done!" "$out_s3"
assert_dir_not_exists "finisher worktree removed" "$WT_S3B"
branch_s3=$(git -C "$REPO" rev-parse --verify "wt/s3-finisher" 2>/dev/null || echo "gone")
assert_eq "finisher branch deleted" "gone" "$branch_s3"
# Verify the commit landed on dev
dev_log_s3=$(git -C "$WT_S3A" log --oneline -5 2>/dev/null || true)
assert_contains "s3 commit landed on dev" "s3 finisher work" "$dev_log_s3"
# Cleanup holder
cd "$REPO"
git -C "$REPO" worktree remove "$WT_S3A" --force 2>/dev/null || true
git -C "$REPO" branch -D "wt/s3-holder" 2>/dev/null || true

# ─── S4: wt finish — local base ahead of origin ──────────────────────────────

section "S4: wt finish — succeeds when local base is ahead of origin"
# Scenario: two worktrees created in parallel from the same dev base (X).
# First finishes → local dev advances to X→A (not pushed, origin stays at X).
# Second then finishes: its branch is based on X (old dev), rebasing onto
# origin/dev (X) is a no-op, but fast-forward from local dev (X→A) fails
# because A is not in the feature branch's ancestry. Fix: rebase onto local
# dev when it's ahead, so feature becomes X→A→B' and ff works.
cd "$REPO"
git -C "$REPO" checkout -q dev

BARE_S4="${TMPROOT}/bare-s4.git"
git -C "$REPO" clone --bare . "$BARE_S4" 2>/dev/null
git -C "$REPO" remote add origin "$BARE_S4" 2>/dev/null \
  || git -C "$REPO" remote set-url origin "$BARE_S4"
git -C "$REPO" fetch origin dev 2>/dev/null

# Create BOTH worktrees from the same dev base (parallel workflow)
WT_S4A="${REPO}/.worktrees/s4-first"
WT_S4B="${REPO}/.worktrees/s4-second"
WT_REGISTRY="$registry_file" bash "$WT" new "s4 first"  >/dev/null 2>&1
WT_REGISTRY="$registry_file" bash "$WT" new "s4 second" >/dev/null 2>&1

echo "s4-first-work" > "${WT_S4A}/s4-first.txt"
git -C "$WT_S4A" add s4-first.txt
git -C "$WT_S4A" commit -q -m "s4 first commit"

echo "s4-second-work" > "${WT_S4B}/s4-second.txt"
git -C "$WT_S4B" add s4-second.txt
git -C "$WT_S4B" commit -q -m "s4 second commit"

# Finish first — local dev advances to X→A; origin/dev stays at X
cd "$WT_S4A"
WT_REGISTRY="$registry_file" bash "$WT" finish --yes >/dev/null 2>&1
cd "$REPO"

# Precondition: origin/dev doesn't have first commit; local dev does
origin_log_s4=$(git -C "$REPO" log origin/dev --oneline 2>/dev/null || true)
assert_not_contains "S4 precondition: origin/dev lacks first commit" \
  "s4 first commit" "$origin_log_s4"

# Now finish second — branch is still based on X (not X→A), so after rebasing
# onto origin/dev (X) the feature tip is X→B; local dev is X→A; X→A is NOT
# an ancestor of X→B → ff fails without the fix
cd "$WT_S4B"
_tmp_s4=$(mktemp)
stdout_s4b=$(WT_REGISTRY="$registry_file" bash "$WT" finish --yes 2>"$_tmp_s4") || true
out_s4b=$(cat "$_tmp_s4"); rm -f "$_tmp_s4"

assert_contains "S4 second finish succeeds despite local base ahead of origin" "Done!" "$out_s4b"
assert_dir_not_exists "S4 second worktree removed" "$WT_S4B"
branch_s4b=$(git -C "$REPO" rev-parse --verify "wt/s4-second" 2>/dev/null || echo "gone")
assert_eq "S4 second branch deleted" "gone" "$branch_s4b"
cd "$REPO"
dev_log_s4=$(git -C "$REPO" log --oneline -5)
assert_contains "S4 first commit landed on dev"  "s4 first commit"  "$dev_log_s4"
assert_contains "S4 second commit landed on dev" "s4 second commit" "$dev_log_s4"

# Cleanup
git -C "$REPO" remote remove origin 2>/dev/null || true
rm -rf "$BARE_S4"

# S5 removed — sync no longer fetches from origin (local merge only)


# ─── M1: slugify strips leading hyphens ──────────────────────────────────────

section "M1: slugify — leading hyphens stripped from slug"
cd "$REPO"
git -C "$REPO" checkout -q dev
# Description starting with hyphens should produce a slug without leading hyphens
# Two leading spaces → after slugify → "-verbose-mode" (pre-fix) or "verbose-mode" (post-fix)
stdout_slug=$(WT_REGISTRY="$registry_file" bash "$WT" new "  verbose mode" 2>/dev/null) || true
WT_SLUG="${REPO}/.worktrees/verbose-mode"
assert_eq "stdout is correct path (no leading hyphens)" "$WT_SLUG" "$stdout_slug"
assert_dir_exists "worktree created at correct path" "$WT_SLUG"
