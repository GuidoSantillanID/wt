#!/usr/bin/env bash
# =============================================================================
# wt — Git Worktree Lifecycle Tool
# =============================================================================
#
# Automates creating, tracking, rebasing, and cleaning up git worktrees for
# parallel development workflows.
#
# COMMANDS
#   wt new "<description>"                      Create a worktree with auto-named branch
#   wt finish [--force]                          Integrate worktree into base (rebase or squash), clean up
#   wt sync                                     Merge local base branch into worktree (LLM-friendly)
#   wt retarget [branch]                        Change this worktree's base branch
#   wt abandon [--yes|-y] [--force]             Abandon worktree without merging, clean up
#   wt pr [--draft] [--yes|-y]                  Push branch and open a GitHub PR (requires gh)
#   wt status                                   Show current worktree info
#   wt list                                     Show all worktrees across projects
#   wt go <branch-or-slug>                      Navigate to an existing worktree
#   wt doctor [--dry-run]                       Check and repair worktree health
#   wt help                                     Show this help
#
# FLAGS
#   --yes / -y   Skip routine confirmation prompts (non-skippable safety gates still prompt)
#   --force      Override non-skippable safety gates (untracked files in finish,
#                unpushed commits in abandon)
#   --dry-run    Show what would happen without making any changes (doctor only)
#
# INSTALLATION
#   1. Run ./install.sh  (copies bin/wt to ~/.local/bin/wt)
#      Or manually: cp bin/wt ~/.local/bin/wt && chmod +x ~/.local/bin/wt
#   2. Add the shell wrapper to ~/.zshrc or ~/.bashrc so that wt new/finish/abandon
#      cd your shell into the new directory:
#
#      # zsh (~/.zshrc):
#      function wt() {
#        if [[ "$1" == "new" || "$1" == "finish" || "$1" == "abandon" || "$1" == "go" ]]; then
#          local dir
#          dir=$(command wt "$@") && [[ -n "$dir" ]] && cd "$dir"
#        else
#          command wt "$@"
#        fi
#      }
#
#      # bash (~/.bashrc):
#      wt() {    # identical syntax, just a different file
#        if [[ "$1" == "new" || "$1" == "finish" || "$1" == "abandon" || "$1" == "go" ]]; then
#          local dir
#          dir=$(command wt "$@") && [[ -n "$dir" ]] && cd "$dir"
#        else
#          command wt "$@"
#        fi
#      }
#
#   3. (Optional) Enable tab completion in zsh — add near the end of ~/.zshrc,
#      after your framework init (oh-my-zsh, prezto) or compinit:
#
#      source ~/.local/bin/wt-completion.zsh
#
# REGISTRY
#   Projects are auto-registered in ${XDG_CONFIG_HOME:-~/.config}/wt/projects
#   when you run `wt new`. Override with WT_REGISTRY env var.
#
# HOW IT WORKS
#   - Worktrees live at <project>/.worktrees/<slug>/
#   - Branch name: wt/<slug> (auto-generated from description)
#   - .wt-meta stores key=value pairs (no quoting, read with cut -d= -f2-)
#   - `wt finish` reads .wt-meta, safety-checks, integrates into base (rebase or squash), removes worktree+branch
#   - `wt abandon` abandons the worktree without merging
#   - Safety gates: --yes skips routine confirms; --force overrides non-skippable gates
#   - Requires bash 4+ (macOS ships with 3.2; install via brew install bash)
#
# =============================================================================

set -euo pipefail

if (( BASH_VERSINFO[0] < 4 )) && [[ "${WT_SKIP_VERSION_CHECK:-}" != "1" ]]; then
  echo "wt requires bash 4+. Current: ${BASH_VERSION}" >&2
  echo "macOS: brew install bash" >&2
  exit 1
fi

# ─── Constants ───────────────────────────────────────────────────────────────

BRANCH_PREFIX="wt"
WORKTREES_DIR=".worktrees"
META_FILE=".wt-meta"

# ─── Registry ────────────────────────────────────────────────────────────────
# Project registry: one absolute path per line, no quoting.
# Override path with WT_REGISTRY env var (for tests and CI).

REGISTRY_FILE="${WT_REGISTRY:-${XDG_CONFIG_HOME:-$HOME/.config}/wt/projects}"
REGISTERED_PROJECTS=()

_load_registry() {
  REGISTERED_PROJECTS=()
  [[ -f "$REGISTRY_FILE" ]] || return 0
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ -z "$line" ]] && continue
    REGISTERED_PROJECTS+=("$line")
  done < "$REGISTRY_FILE"
}

_register_project() {
  local path="$1"
  mkdir -p "$(dirname "$REGISTRY_FILE")"
  grep -qxF "$path" "$REGISTRY_FILE" 2>/dev/null || echo "$path" >> "$REGISTRY_FILE"
  # Reload so REGISTERED_PROJECTS stays current within this process
  _load_registry
}

_unregister_project() {
  local path="$1"
  [[ -f "$REGISTRY_FILE" ]] || return 0
  local tmp
  tmp=$(mktemp)
  grep -vxF "$path" "$REGISTRY_FILE" > "$tmp" || true
  if [[ -s "$tmp" ]]; then
    mv "$tmp" "$REGISTRY_FILE"
  else
    rm -f "$tmp" "$REGISTRY_FILE"
  fi
  _load_registry
}

_load_registry

# ─── Colors ──────────────────────────────────────────────────────────────────
# Check stdout (fd 1) — `wt list` outputs to stdout, and that's the only
# command where piping matters. new/done write UI to stderr, which is fine.

if [[ -t 1 ]]; then
  RED='\033[0;31m'
  YELLOW='\033[0;33m'
  GREEN='\033[0;32m'
  CYAN='\033[0;36m'
  BOLD='\033[1m'
  RESET='\033[0m'
else
  RED='' YELLOW='' GREEN='' CYAN='' BOLD='' RESET=''
fi

# ─── Helpers ─────────────────────────────────────────────────────────────────

# All UI output goes to stderr — stdout is reserved for returning paths to the
# shell wrapper for `cd`.
info()    { echo -e "${CYAN}→${RESET} $*" >&2; }
success() { echo -e "${GREEN}✓${RESET} $*" >&2; }
warn()    { echo -e "${YELLOW}⚠${RESET} $*" >&2; }
error()   { echo -e "${RED}✗${RESET} $*" >&2; exit 1; }

confirm() {
  local prompt="$1"
  local response
  echo -en "${BOLD}${prompt}${RESET} [y/N] " >&2
  read -r response
  [[ "$response" =~ ^[Yy]$ ]]
}

# Slugify a description string:
# "Fix the Sidebar Overflow Bug!" → "fix-the-sidebar-overflow-bug"
slugify() {
  echo "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | sed 's/[^a-z0-9 -]//g' \
    | tr -s ' ' '-' \
    | cut -c1-50 \
    | sed 's/-$//' \
    | sed 's/^-*//'
}

# Get the main worktree path (the first entry in `git worktree list`)
get_main_worktree() {
  git worktree list --porcelain 2>/dev/null \
    | awk '/^worktree /{ if (!f) { sub(/^worktree /, ""); f=$0 } } END { print f }'
}

# Safely read a single key from a .wt-meta file
# Format: key=value (plain, no quoting — values must not contain newlines)
read_meta() {
  local file="$1" key="$2"
  grep "^${key}=" "$file" 2>/dev/null | head -1 | cut -d= -f2- || true
}

# Human-readable age from a YYYY-MM-DDTHH:MM:SS timestamp
# Supports both GNU date (Linux) and BSD date (macOS).
human_age() {
  local ts="$1"
  local now then diff
  now=$(date +%s)
  # Try GNU date first, fall back to BSD date
  then=$(date -d "$ts" +%s 2>/dev/null) \
    || then=$(date -j -f "%Y-%m-%dT%H:%M:%S" "$ts" +%s 2>/dev/null) \
    || then="$now"
  diff=$(( now - then ))
  if   (( diff < 3600   )); then echo "$(( diff / 60 ))m ago"
  elif (( diff < 86400  )); then echo "$(( diff / 3600 ))h ago"
  elif (( diff < 604800 )); then echo "$(( diff / 86400 ))d ago"
  else                          echo "$(( diff / 604800 ))w ago"
  fi
}

# ─── Commands ────────────────────────────────────────────────────────────────

cmd_help() {
  cat <<'HELP'
wt — Git Worktree Lifecycle Tool

USAGE
  wt new "<description>"                      Create a worktree with auto-named branch
  wt finish [--force]                          Integrate worktree into base (rebase or squash), clean up
  wt sync                                     Merge local base branch into worktree (LLM-friendly)
  wt retarget [branch]                        Change this worktree's base branch
  wt abandon [--yes|-y] [--force]             Abandon worktree without merging, clean up
  wt pr [--draft] [--yes|-y]                  Push branch and open a GitHub PR (requires gh)
  wt status                                   Show current worktree info
  wt list                                     Show all active worktrees across projects
  wt go <branch-or-slug>                      Navigate to an existing worktree
  wt doctor [--dry-run]                       Check for orphaned branches/dirs, fix interactively
  wt help                                     Show this help

EXAMPLES
  # From inside a project dir:
  wt new "fix the sidebar overflow bug"

  # Integrate worktree into base and clean up (run from inside a worktree):
  wt finish

  # Merge local base into worktree (keeps worktree up to date):
  wt sync

  # Abandon a dead-end worktree without merging:
  wt abandon

  # Push and open a GitHub PR (from inside a worktree):
  wt pr

  # Open a draft PR:
  wt pr --draft

  # Show current worktree info:
  wt status

  # List all active worktrees:
  wt list

NOTES
  • Run `wt new` from inside a project — it registers the project automatically
  • Worktrees are created at <project>/.worktrees/<slug>/
  • Branch names: wt/<slug> (auto-generated from your description)
  • After `wt new`, your shell cd's into the new worktree
  • After `wt finish`, your shell cd's back to the main worktree
  • `wt go <branch-or-slug>` navigates to an existing worktree (useful after reopening a shell)
  • Pass --yes / -y to wt abandon or wt pr to skip confirmation prompts
  • Pass --force to wt finish or wt abandon to override non-skippable safety gates
  • `wt sync` merges local base into the worktree — on conflict, shows LLM-friendly context
  • `wt pr` requires the GitHub CLI (gh) — https://cli.github.com
  • `wt pr` rebases before pushing when the branch is clean; skips rebase when merge commits are present (from wt sync)
  • After merging a PR on GitHub, run `wt abandon` to clean up the worktree
  • `wt finish` auto-detects merge commits from `wt sync` and uses squash instead of rebase
  • Projects are tracked in ${XDG_CONFIG_HOME:-~/.config}/wt/projects (one path per line)
  • Override registry path: export WT_REGISTRY=/path/to/registry
  • Inside tmux, cleanup commands (finish/abandon) show a reminder to close the current window
HELP
}

# wt new "<description>"
cmd_new() {
  local description=""

  # Extract flags
  local args=()
  for arg in "$@"; do
    case "$arg" in
      -*) error "Unknown flag: $arg" ;;
      *) args+=("$arg") ;;
    esac
  done
  set -- "${args[@]}"

  case $# in
    0) error "Usage: wt new \"<description>\"" ;;
    1) description="$1" ;;
    *) error "Usage: wt new \"<description>\"" ;;
  esac

  [[ -z "$description" ]] && error "Description cannot be empty"

  # Resolve project root
  local project_root
  project_root=$(git rev-parse --show-toplevel 2>/dev/null) \
    || error "Not inside a git repository. Run from inside a project."

  # If inside a worktree (not main checkout), redirect to actual project root.
  # A worktree has a .git *file*; main checkout has a .git *directory*.
  if [[ -f "${project_root}/.git" ]]; then
    project_root=$(get_main_worktree) \
      || error "Could not resolve main worktree path"
    local main_branch
    main_branch=$(git -C "$project_root" symbolic-ref --short HEAD 2>/dev/null || echo "unknown")
    info "Detected worktree context — branching from main checkout (${main_branch}): ${project_root}"
  fi

  _register_project "$project_root"

  local project_name
  project_name=$(basename "$project_root")

  local slug
  slug=$(slugify "$description")
  [[ -z "$slug" ]] && error "Could not generate a slug from: '$description'"

  local branch="${BRANCH_PREFIX}/${slug}"
  local worktree_path="${project_root}/${WORKTREES_DIR}/${slug}"

  # Conflict checks
  [[ -d "$worktree_path" ]] && error "Worktree already exists: $worktree_path"
  git -C "$project_root" rev-parse --verify "$branch" &>/dev/null \
    && error "Branch already exists: $branch"

  # Record current branch as merge target
  local base_branch
  base_branch=$(git -C "$project_root" symbolic-ref --short HEAD 2>/dev/null) \
    || error "Could not determine current branch in $project_root"

  local created
  created=$(date '+%Y-%m-%dT%H:%M:%S')

  mkdir -p "${project_root}/${WORKTREES_DIR}"

  # Exclude .worktrees/ from git status via info/exclude (repo-local, not committed).
  # project_root is always the main worktree here (resolved above), so .git is a directory.
  mkdir -p "${project_root}/.git/info"
  if ! grep -qxF ".worktrees/" "${project_root}/.git/info/exclude" 2>/dev/null; then
    echo ".worktrees/" >> "${project_root}/.git/info/exclude"
  fi

  info "Creating worktree: ${BOLD}${project_name}/.worktrees/${slug}${RESET}"
  info "Branch: ${BOLD}${branch}${RESET} (base: ${base_branch})"

  git -C "$project_root" worktree add "$worktree_path" -b "$branch" >&2 \
    || error "Failed to create git worktree"

  # Write .wt-meta — plain key=value, no quoting.
  # Values must not contain newlines (descriptions are single-line by design).
  # Read with read_meta() using cut -d= -f2-, no eval.
  cat > "${worktree_path}/${META_FILE}" <<EOF
base_branch=${base_branch}
created=${created}
description=${description}
project=${project_name}
project_root=${project_root}
slug=${slug}
branch=${branch}
EOF

  # Exclude .wt-meta from git status.
  # info/exclude lives under GIT_COMMON_DIR (the main .git dir, shared by all worktrees).
  # We only append if not already present to avoid duplicate entries.
  local common_dir
  common_dir=$(git -C "$worktree_path" rev-parse --git-common-dir 2>/dev/null || echo "")
  if [[ -n "$common_dir" ]]; then
    mkdir -p "${common_dir}/info"
    if ! grep -qxF ".wt-meta" "${common_dir}/info/exclude" 2>/dev/null; then
      echo ".wt-meta" >> "${common_dir}/info/exclude"
    fi
  fi

  success "Worktree created: ${worktree_path}"
  info "Worktrees share git history but not installed dependencies — run your package manager if needed."

  # Return path on stdout for shell wrapper to cd into
  echo "$worktree_path"
}

# wt retarget [branch] — change this worktree's base branch in .wt-meta
cmd_retarget() {
  local repo_root
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null) \
    || error "Not inside a git repository"

  [[ -d "${repo_root}/.git" ]] \
    && error "You are in the main checkout, not a worktree."

  local meta_file="${repo_root}/${META_FILE}"
  [[ -f "$meta_file" ]] \
    || error "No ${META_FILE} found. Was this worktree created with 'wt new'?"

  local base_branch branch description
  base_branch=$(read_meta "$meta_file" "base_branch")
  branch=$(read_meta "$meta_file" "branch")
  description=$(read_meta "$meta_file" "description")

  [[ -z "$base_branch" || -z "$branch" ]] \
    && error "Corrupt .wt-meta — missing required fields"

  local new_base=""

  if [[ -n "${1:-}" ]]; then
    # Branch provided as argument — validate it exists locally or as origin/<branch>
    local target="$1"
    if git rev-parse --verify "$target" &>/dev/null \
        || git rev-parse --verify "origin/$target" &>/dev/null; then
      new_base="$target"
    else
      error "Branch not found: '${target}' (checked local and origin/${target})"
    fi
  else
    # Interactive picker: list remote branches, fall back to local
    echo -e "  Current base: ${BOLD}${base_branch}${RESET}" >&2
    new_base=$(_pick_base_branch "${branch}" "$base_branch") || {
      error "No other branches found to retarget onto."
    }
    if [[ -z "$new_base" ]]; then
      warn "Invalid choice. Aborted."
      exit 0
    fi
  fi

  if [[ "$new_base" == "$base_branch" ]]; then
    info "Already targeting ${BOLD}${new_base}${RESET} — no change."
    return 0
  fi

  sed -i.bak "s|^base_branch=.*|base_branch=${new_base}|" "$meta_file" \
    && rm -f "${meta_file}.bak"

  success "Base branch changed: ${BOLD}${base_branch}${RESET} → ${BOLD}${new_base}${RESET}"
  info "Run 'wt sync' to merge the new base, or 'wt finish' when done."
}

# Fetch origin/<base_branch> and rebase current branch onto it (fall back to local).
# Prints progress to stderr. Does NOT handle conflicts — caller must.
# Returns: git rebase exit code (non-zero on conflict).
_rebase_onto_base() {
  local base_branch="$1" branch="$2" prefer_local="${3:-}"
  info "Fetching origin/${base_branch}..."
  git fetch origin "${base_branch}" >&2 2>/dev/null \
    || warn "Could not fetch origin/${base_branch} — will rebase onto local ref"
  local rebase_target="${base_branch}"
  if git rev-parse --verify "origin/${base_branch}" &>/dev/null; then
    if [[ "$prefer_local" == "--prefer-local" ]]; then
      # Use whichever ref is further ahead so the ff target (local base) is
      # always an ancestor of the rebase target.
      if git merge-base --is-ancestor "${base_branch}" "origin/${base_branch}" 2>/dev/null; then
        rebase_target="origin/${base_branch}"   # origin ahead or equal
      elif ! git merge-base --is-ancestor "origin/${base_branch}" "${base_branch}" 2>/dev/null; then
        rebase_target="origin/${base_branch}"   # diverged — use origin, warn
        warn "Local ${base_branch} has diverged from origin/${base_branch} — rebasing onto origin."
      fi
      # else: local strictly ahead — keep rebase_target as local base_branch
    else
      rebase_target="origin/${base_branch}"     # default: always prefer origin
    fi
  else
    warn "No remote-tracking branch — using local ${base_branch}"
  fi
  info "Rebasing ${branch} onto ${rebase_target}..."
  trap 'git rebase --abort 2>/dev/null || true; warn "Interrupted."; exit 130' INT
  git rebase "${rebase_target}" >&2
  local _rc=$?
  trap - INT
  return $_rc
}

# Fast-forward base_branch to ff_ref using two strategies.
# Strategy 1: local fetch (works when base_branch is not checked out in current worktree)
# Strategy 2: find a worktree with base_branch checked out, merge --ff-only there
# Args: <ff_ref> <base_branch> <repo_root> <branch>
#   ff_ref      — commit/ref to advance base_branch to (resolved to SHA for portability)
#   base_branch — branch to fast-forward
#   repo_root   — current worktree root (skipped in worktree scan)
#   branch      — feature branch name (used in manual-fix instructions)
_ff_onto_base() {
  local ff_ref="$1" base_branch="$2" repo_root="$3" branch="$4"
  local ff_sha
  ff_sha=$(git rev-parse "${ff_ref}^{commit}")
  # Strategy 1: from within this worktree (works when base_branch is NOT checked out here)
  local ff_err
  if ff_err=$(git fetch . "${ff_sha}:refs/heads/${base_branch}" 2>&1); then
    success "Fast-forward successful"
  else
    # Strategy 2: find any worktree that has base_branch checked out
    local ff_wt=""
    while IFS= read -r porcelain_line; do
      if [[ "$porcelain_line" == worktree\ * ]]; then
        local wt_cand="${porcelain_line#worktree }"
        [[ "$wt_cand" == "$repo_root" ]] && continue
        local wt_cand_branch
        wt_cand_branch=$(git -C "$wt_cand" symbolic-ref --short HEAD 2>/dev/null || echo "")
        if [[ "$wt_cand_branch" == "$base_branch" ]]; then
          ff_wt="$wt_cand"
          break
        fi
      fi
    done < <(git worktree list --porcelain 2>/dev/null)
    if [[ -n "$ff_wt" ]]; then
      local merge_err
      if merge_err=$(git -C "$ff_wt" merge --ff-only "$ff_sha" 2>&1); then
        success "Fast-forward successful (from worktree: $(basename "$ff_wt"))"
      else
        warn "Fast-forward failed: ${merge_err}"
        echo -e "Resolve manually:" >&2
        echo -e "  cd ${ff_wt} && git merge --ff-only ${ff_sha}" >&2
        echo -e "  # then: git worktree remove ${repo_root} && git branch -D ${branch}" >&2
        exit 1
      fi
    else
      warn "Could not fast-forward: '${base_branch}' is not checked out in any worktree."
      echo -e "Resolve manually:" >&2
      echo -e "  cd <a worktree on ${base_branch}> && git merge --ff-only ${ff_sha}" >&2
      echo -e "  git worktree remove ${repo_root} && git branch -D ${branch}" >&2
      exit 1
    fi
  fi
}

# Interactive branch picker. Lists remote branches, optionally falls back to local.
# Args: <exclude_branch> <current_base> [--no-fallback]
# Prints selected branch name to stdout (empty if invalid choice / EOF).
# Returns 1 if no branches found at all, 0 otherwise.
_pick_base_branch() {
  local exclude_branch="$1" current_base="$2"
  local fallback=1
  [[ "${3:-}" == "--no-fallback" ]] && fallback=0

  local branches=()
  while IFS= read -r b; do
    branches+=("$b")
  done < <(
    git branch -r --list 'origin/*' 2>/dev/null \
      | sed -e 's/^[[:space:]]*//' -e '/HEAD/d' -e 's|^origin/||' \
      | grep -v "^${exclude_branch}$" \
      | sort
  )

  if (( ${#branches[@]} == 0 )) && (( fallback == 1 )); then
    while IFS= read -r b; do
      branches+=("$b")
    done < <(
      git branch 2>/dev/null \
        | sed -e 's/^[[:space:]]*//' -e 's/^\* //' \
        | grep -v "^${exclude_branch}$" \
        | sort
    )
  fi

  if (( ${#branches[@]} == 0 )); then
    return 1
  fi

  echo -e "  Pick a new base branch:" >&2
  local i
  for i in "${!branches[@]}"; do
    local marker=""
    [[ -n "$current_base" && "${branches[$i]}" == "$current_base" ]] && marker=" (current)"
    echo -e "    $((i+1))) ${branches[$i]}${marker}" >&2
  done
  local choice
  echo -en "  ${BOLD}Enter number [1-${#branches[@]}]:${RESET} " >&2
  read -r choice || true
  if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#branches[@]} )); then
    echo "${branches[$((choice-1))]}"
  fi
}

# wt finish — rebase worktree onto base, fast-forward, clean up
cmd_finish() {
  local force=0
  for arg in "$@"; do
    case "$arg" in
      --yes|-y)  : ;;  # accepted for backwards compatibility (no prompts to skip)
      --force)   force=1 ;;
    esac
  done

  local repo_root
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null) \
    || error "Not inside a git repository"

  [[ -d "${repo_root}/.git" ]] \
    && error "You are in the main checkout, not a worktree."

  local meta_file="${repo_root}/${META_FILE}"
  [[ -f "$meta_file" ]] \
    || error "No ${META_FILE} found. Was this worktree created with 'wt new'?"

  local base_branch description project project_root slug branch
  base_branch=$(read_meta "$meta_file" "base_branch")
  description=$(read_meta "$meta_file" "description")
  project=$(read_meta "$meta_file" "project")
  project_root=$(read_meta "$meta_file" "project_root")
  slug=$(read_meta "$meta_file" "slug")
  branch=$(read_meta "$meta_file" "branch")

  [[ -z "$base_branch" || -z "$branch" ]] \
    && error "Corrupt .wt-meta — missing required fields"

  info "Worktree: ${BOLD}${branch}${RESET}"
  info "Description: ${description}"
  info "Base branch: ${BOLD}${base_branch}${RESET}"

  # Safety: tracked uncommitted changes (must commit/stash before rebase)
  if git status --porcelain | grep -qv '^??'; then
    error "Uncommitted changes present. Commit or stash before 'wt finish'."
  fi

  # Safety: untracked files (git worktree remove --force will permanently delete them)
  # Non-skippable: --yes does not bypass; only --force overrides.
  if git status --porcelain | grep -q '^??'; then
    warn "Untracked files in this worktree will be permanently deleted."
    if (( force == 0 )); then
      confirm "Continue? Untracked files will be lost." || { info "Aborted."; exit 0; }
    fi
  fi

  local main_wt
  main_wt=$(get_main_worktree)
  [[ -z "$main_wt" ]] && error "Could not determine main worktree path"

  # Detect merge commits (created by wt sync) to choose strategy.
  # Merge commits present → squash path. Clean history → rebase path.
  local has_merges use_squash
  has_merges=$(git rev-list --merges "${base_branch}..HEAD" | head -1)
  use_squash=0
  [[ -n "$has_merges" ]] && use_squash=1

  if (( use_squash )); then
    # Pre-flight: base_branch must be an ancestor of HEAD (i.e. wt sync was run).
    # If it's not, there are new base commits the worktree hasn't merged yet.
    if ! git merge-base --is-ancestor "$base_branch" HEAD 2>/dev/null; then
      warn "Base branch has commits not yet in this worktree."
      echo -e "  Run 'wt sync' first, then retry 'wt finish'." >&2
      exit 1
    fi
    # Create a single squash commit: tree from HEAD (all changes), parent = base_branch only.
    local squash_commit
    squash_commit=$(git commit-tree "HEAD^{tree}" -p "$base_branch" -m "$description")
    # Fast-forward base to the squash commit.
    _ff_onto_base "$squash_commit" "$base_branch" "$repo_root" "$branch"
    _cleanup_worktree "$repo_root" "$branch" "$main_wt" "$project" "$slug" "force" "$project_root"
    success "Done! Worktree squash-merged and cleaned up."
    echo "$main_wt"
    return 0
  fi

  # Rebase path (no merge commits — clean linear history)
  if ! _rebase_onto_base "$base_branch" "$branch" --prefer-local; then
    git rebase --abort 2>/dev/null || true
    warn "Rebase conflict. Aborted."
    echo -e "  Run 'wt sync' to merge the base branch, resolve conflicts, then retry 'wt finish'." >&2
    exit 1
  fi
  trap - INT
  success "Rebase successful"

  # Fast-forward base to the rebased tip.
  _ff_onto_base HEAD "$base_branch" "$repo_root" "$branch"

  # Safe to force-delete: branch is already in base_branch via the fast-forward above.
  _cleanup_worktree "$repo_root" "$branch" "$main_wt" "$project" "$slug" "force" "$project_root"

  success "Done! Worktree rebased, integrated, and cleaned up."
  echo "$main_wt"
}

# wt sync — merge local base branch into worktree (LLM-friendly)
cmd_sync() {
  local repo_root
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null) \
    || error "Not inside a git repository"

  [[ -d "${repo_root}/.git" ]] \
    && error "You are in the main checkout, not a worktree."

  local meta_file="${repo_root}/${META_FILE}"
  [[ -f "$meta_file" ]] \
    || error "No ${META_FILE} found. Was this worktree created with 'wt new'?"

  local base_branch description branch
  base_branch=$(read_meta "$meta_file" "base_branch")
  description=$(read_meta "$meta_file" "description")
  branch=$(read_meta "$meta_file" "branch")

  [[ -z "$base_branch" || -z "$branch" ]] \
    && error "Corrupt .wt-meta — missing required fields"

  info "Worktree: ${BOLD}${branch}${RESET}"
  info "Description: ${description}"
  info "Base branch: ${BOLD}${base_branch}${RESET}"

  # Safety: in-progress merge or rebase
  local git_dir
  git_dir=$(git rev-parse --git-dir)
  if [[ -f "${git_dir}/MERGE_HEAD" ]]; then
    error "A merge is already in progress. Run 'git merge --continue' or 'git merge --abort' first."
  fi
  if [[ -d "${git_dir}/rebase-merge" ]] || [[ -d "${git_dir}/rebase-apply" ]]; then
    error "A rebase is already in progress. Run 'git rebase --continue' or 'git rebase --abort' first."
  fi

  # Safety: uncommitted tracked changes (untracked files are OK)
  if git status --porcelain | grep -qv '^??'; then
    error "Uncommitted changes present. Commit or stash before 'wt sync'."
  fi

  # Check: base branch ref must exist locally
  if ! git rev-parse --verify "${base_branch}" &>/dev/null; then
    error "Base branch '${base_branch}' not found locally. Run 'git fetch' or 'wt retarget'."
  fi

  # Check: already up to date
  if git merge-base --is-ancestor "${base_branch}" HEAD 2>/dev/null; then
    success "Already up to date with ${base_branch}."
    return 0
  fi

  info "Merging ${base_branch} into ${branch}..."
  local merge_output
  if merge_output=$(git merge --no-edit "${base_branch}" 2>&1); then
    success "Merged ${base_branch} into ${branch}."
  else
    warn "Merge conflicts detected."
    echo "" >&2

    # Determine conflicted files
    local conflicted_set
    conflicted_set=$(git diff --name-only --diff-filter=U)

    # Show auto-merged files (appeared in git output but not in conflict set)
    local auto_merged_str=""
    while IFS= read -r f; do
      [[ -z "$f" ]] && continue
      if ! printf '%s\n' "$conflicted_set" | grep -qxF "$f"; then
        [[ -n "$auto_merged_str" ]] && auto_merged_str="${auto_merged_str}, "
        auto_merged_str="${auto_merged_str}${f}"
      fi
    done < <(printf '%s\n' "$merge_output" | grep '^Auto-merging ' | awk '{print $2}')
    if [[ -n "$auto_merged_str" ]]; then
      echo "✓ Auto-merged: ${auto_merged_str}" >&2
      echo "" >&2
    fi

    # Show conflicted files with line numbers and commit context
    echo "✗ Conflicted files:" >&2
    local merge_base
    merge_base=$(git merge-base HEAD MERGE_HEAD)
    while IFS= read -r file; do
      [[ -z "$file" ]] && continue
      local lines count label
      lines=$(grep -n '^<<<<<<<' "$file" | cut -d: -f1 | paste -sd, -)
      count=$(grep -c '^<<<<<<<' "$file" || echo 0)
      [[ "$count" -eq 1 ]] && label="conflict" || label="conflicts"
      echo "  ${file}:${lines} (${count} ${label})" >&2
      echo "    HEAD:" >&2
      git log --oneline "${merge_base}..HEAD" -- "$file" | sed 's/^/      /' >&2
      echo "    ${base_branch}:" >&2
      git log --oneline "${merge_base}..MERGE_HEAD" -- "$file" | sed 's/^/      /' >&2
    done <<< "$conflicted_set"

    echo "" >&2
    warn "Resolve conflicts, then run:"
    echo -e "  git add <resolved-files>" >&2
    echo -e "  git merge --continue" >&2
    echo -e "  To abort:  git merge --abort" >&2
    exit 1
  fi
}

# wt abandon — abandon worktree without merging
cmd_abandon() {
  local auto_yes=0 force=0 target=""
  for arg in "$@"; do
    case "$arg" in
      --yes|-y)  auto_yes=1 ;;
      --force)   force=1 ;;
      -*)        error "Unknown flag: $arg" ;;
      *)         [[ -z "$target" ]] && target="$arg" \
                   || error "Usage: wt abandon [<branch-or-slug>] [--yes|-y] [--force]" ;;
    esac
  done

  if [[ -n "$target" ]]; then
    local resolved
    resolved=$(_resolve_worktree "$target")
    cd "$resolved"
  fi

  local repo_root
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null) \
    || error "Not inside a git repository"

  [[ -d "${repo_root}/.git" ]] \
    && error "You are in the main checkout, not a worktree."

  local meta_file="${repo_root}/${META_FILE}"
  [[ -f "$meta_file" ]] \
    || error "No ${META_FILE} found. Was this worktree created with 'wt new'?"

  local base_branch description project project_root slug branch
  base_branch=$(read_meta "$meta_file" "base_branch")
  description=$(read_meta "$meta_file" "description")
  project=$(read_meta "$meta_file" "project")
  project_root=$(read_meta "$meta_file" "project_root")
  slug=$(read_meta "$meta_file" "slug")
  branch=$(read_meta "$meta_file" "branch")

  [[ -z "$branch" ]] && error "Corrupt .wt-meta — missing branch field"

  info "Worktree: ${BOLD}${branch}${RESET}"
  info "Description: ${description}"
  warn "This will DELETE the worktree and branch WITHOUT merging. Work will be lost."

  # Safety: uncommitted changes
  if [[ -n "$(git status --porcelain)" ]]; then
    warn "There are uncommitted changes in this worktree."
    if (( auto_yes == 0 )); then
      confirm "Drop anyway (changes will be lost)?" || exit 0
    fi
  fi

  # Safety: unpushed commits (non-skippable gate — --yes does not bypass; --force overrides)
  if [[ -n "$base_branch" ]]; then
    local ahead_count
    ahead_count=$(git rev-list --count "${base_branch}..HEAD" 2>/dev/null || echo 0)
    if (( ahead_count > 0 )); then
      warn "${ahead_count} unpushed commit(s) on this branch:"
      git log --oneline "${base_branch}..HEAD" >&2
      if (( force == 0 )); then
        confirm "Drop ${ahead_count} unpushed commit(s)? (use --force to skip)" \
          || { info "Aborted."; exit 0; }
      fi
    fi
  else
    warn "Could not determine base branch — assuming commits may be unpushed."
    if (( force == 0 )); then
      confirm "Proceed with drop anyway?" || { info "Aborted."; exit 0; }
    fi
  fi


  if (( auto_yes == 0 )); then
    confirm "Drop ${BOLD}${branch}${RESET}? (no merge)" || { info "Aborted."; exit 0; }
  fi

  local main_wt
  main_wt=$(get_main_worktree)
  [[ -z "$main_wt" ]] && error "Could not determine main worktree path"

  _cleanup_worktree "$repo_root" "$branch" "$main_wt" "$project" "$slug" "force" "$project_root"

  success "Dropped. Worktree removed, branch deleted (unmerged)."
  echo "$main_wt"
}

cmd_pr() {
  local auto_yes=0 draft_flag=""
  for arg in "$@"; do
    case "$arg" in
      --yes|-y) auto_yes=1 ;;
      --draft)  draft_flag="--draft" ;;
      *)        error "Unknown flag: '$arg'. Usage: wt pr [--draft] [--yes|-y]" ;;
    esac
  done

  command -v gh &>/dev/null \
    || error "gh CLI required for 'wt pr'. Install: https://cli.github.com"

  local repo_root
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null) \
    || error "Not inside a git repository"

  [[ -d "${repo_root}/.git" ]] \
    && error "You are in the main checkout, not a worktree."

  local meta_file="${repo_root}/${META_FILE}"
  [[ -f "$meta_file" ]] \
    || error "No ${META_FILE} found. Was this worktree created with 'wt new'?"

  local base_branch description branch
  base_branch=$(read_meta "$meta_file" "base_branch")
  description=$(read_meta "$meta_file" "description")
  branch=$(read_meta "$meta_file" "branch")

  [[ -z "$base_branch" || -z "$branch" ]] \
    && error "Corrupt .wt-meta — missing required fields"

  info "Worktree: ${BOLD}${branch}${RESET}"
  info "Description: ${description}"
  info "Base branch: ${BOLD}${base_branch}${RESET}"

  [[ -n "$(git status --porcelain)" ]] \
    && error "Uncommitted changes present. Commit or stash before 'wt pr'."

  info "To change the base branch, run: ${BOLD}wt retarget${RESET}"

  git remote get-url origin &>/dev/null \
    || error "No 'origin' remote configured. 'wt pr' requires a remote to push to."

  # Skip rebase when merge commits are present (created by wt sync).
  # Rebasing would re-encounter conflicts already resolved by the merge.
  # Use || true so an unresolvable base_branch ref (remote-only after retarget) defaults to rebase.
  local pr_has_merges
  pr_has_merges=$(git rev-list --merges "${base_branch}..HEAD" 2>/dev/null | head -1 || true)
  if [[ -z "$pr_has_merges" ]]; then
    if ! _rebase_onto_base "$base_branch" "$branch"; then
      warn "Rebase paused — conflicts detected."
      echo -e "  Fix conflicts, then:  git add <files> && git rebase --continue" >&2
      echo -e "  To abort:             git rebase --abort && git checkout ${branch}" >&2
      exit 1
    fi
    success "Rebased onto ${base_branch}"
  fi

  info "Pushing ${branch} to origin..."
  git push --force-with-lease origin "${branch}" >&2 \
    || error "Push failed. Check your remote access."
  success "Pushed ${branch}"

  local existing_pr
  existing_pr=$(gh pr view --json url --jq '.url' 2>/dev/null || echo "")
  if [[ -n "$existing_pr" ]]; then
    success "PR already exists — pushed latest changes"
    info "URL: ${existing_pr}"
    echo "$existing_pr"
    return 0
  fi

  local pr_body
  pr_body=$(git log --oneline --reverse "origin/${base_branch}..HEAD" 2>/dev/null \
    | sed 's/^/- /' || echo "")

  if (( auto_yes == 0 )); then
    confirm "Open PR: '${description}' → ${base_branch}?" \
      || { info "Aborted."; exit 0; }
  fi

  local pr_url
  pr_url=$(gh pr create \
    --base "$base_branch" \
    --title "$description" \
    --body "$pr_body" \
    ${draft_flag:+"$draft_flag"} 2>/dev/null) \
    || error "Failed to create PR. Check 'gh auth status'."

  success "PR created"
  info "URL: ${pr_url}"
  echo "$pr_url"
}

cmd_status() {
  local repo_root
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null) \
    || error "Not inside a git repository"

  [[ -d "${repo_root}/.git" ]] \
    && error "You are in the main checkout, not a worktree."

  local meta_file="${repo_root}/${META_FILE}"
  [[ -f "$meta_file" ]] \
    || error "No ${META_FILE} found. Was this worktree created with 'wt new'?"

  local base_branch description branch created
  base_branch=$(read_meta "$meta_file" "base_branch")
  description=$(read_meta "$meta_file" "description")
  branch=$(read_meta "$meta_file" "branch")
  created=$(read_meta "$meta_file" "created")

  [[ -z "$base_branch" || -z "$branch" ]] \
    && error "Corrupt .wt-meta — missing required fields"

  local dirty_count ahead age
  dirty_count=$(git status --porcelain 2>/dev/null | wc -l | tr -d ' ')
  ahead=$(git rev-list --count "${base_branch}..HEAD" 2>/dev/null || echo 0)
  age="?"
  [[ -n "$created" ]] && age=$(human_age "$created")

  echo -e "${BOLD}${branch}${RESET}" >&2
  echo -e "  Description:  ${description}" >&2
  echo -e "  Base branch:  ${base_branch}" >&2
  echo -e "  Commits:      ${ahead} ahead" >&2
  if (( dirty_count > 0 )); then
    echo -e "  Working tree: ${YELLOW}${dirty_count} dirty${RESET}" >&2
  else
    echo -e "  Working tree: ${GREEN}clean${RESET}" >&2
  fi
  echo -e "  Age:          ${age}" >&2

  if command -v gh &>/dev/null \
      && git remote -v 2>/dev/null | grep -q 'github\.com'; then
    local pr_url
    pr_url=$(gh pr view --json url --jq '.url' 2>/dev/null || echo "")
    [[ -n "$pr_url" ]] && echo -e "  PR:           ${pr_url}" >&2
  fi
}

# Shared cleanup: remove worktree dir, delete branch
# Args: repo_root branch main_wt project slug delete_mode [project_root]
# delete_mode: "merged" → git branch -d (safe); "force" → git branch -D
_cleanup_worktree() {
  local repo_root="$1" branch="$2" main_wt="$3" project="$4" slug="$5"
  local delete_mode="${6:-force}" project_root="${7:-}"

  info "Removing worktree..."
  git -C "$main_wt" worktree remove "$repo_root" --force >&2 \
    || warn "Could not auto-remove worktree dir. Run: rm -rf ${repo_root}"

  info "Deleting branch ${branch}..."
  if [[ "$delete_mode" == "force" ]]; then
    git -C "$main_wt" branch -D "$branch" >&2 \
      || warn "Could not force-delete branch ${branch}"
  else
    git -C "$main_wt" branch -d "$branch" >&2 \
      || warn "Could not delete branch ${branch}"
  fi

  # Auto-unregister project if no worktrees or wt/* branches remain
  if [[ -n "$project_root" ]]; then
    local has_wts=0
    if [[ -d "${project_root}/${WORKTREES_DIR}" ]]; then
      for wt_dir in "${project_root}/${WORKTREES_DIR}"/*/; do
        [[ -d "$wt_dir" ]] && has_wts=1 && break
      done
    fi
    local wt_branch_count
    wt_branch_count=$(git -C "$project_root" branch --list 'wt/*' 2>/dev/null | wc -l | tr -d ' ')
    if (( has_wts == 0 && wt_branch_count == 0 )); then
      _unregister_project "$project_root"
    fi
  fi

  # Hint: user can close this tmux window now
  if [[ -n "${TMUX:-}" ]]; then
    echo -e "\n  ${BOLD}You can now close this tmux window.${RESET}\n" >&2
  fi
}

# wt list — show all active worktrees across projects
cmd_list() {
  local found=0
  local current_project=""

  while IFS= read -r meta_file; do
    [[ -f "$meta_file" ]] || continue

    local wt_dir
    wt_dir=$(dirname "$meta_file")

    local base_branch description project created branch
    base_branch=$(read_meta "$meta_file" "base_branch")
    description=$(read_meta "$meta_file" "description")
    project=$(read_meta "$meta_file" "project")
    created=$(read_meta "$meta_file" "created")
    branch=$(read_meta "$meta_file" "branch")

    [[ -z "$branch" ]] && continue

    if git -C "$wt_dir" rev-parse --git-dir &>/dev/null; then
      local dirty_count dirty_label
      dirty_count=$(git -C "$wt_dir" status --porcelain 2>/dev/null | wc -l | tr -d ' ')
      if (( dirty_count > 0 )); then dirty_label="${dirty_count} dirty"; else dirty_label="clean"; fi

      local ahead
      ahead=$(git -C "$wt_dir" rev-list --count "${base_branch}..HEAD" 2>/dev/null || echo 0)

      local age="?"
      [[ -n "$created" ]] && age=$(human_age "$created")

      if [[ "$project" != "$current_project" ]]; then
        [[ -n "$current_project" ]] && echo ""
        echo -e "${BOLD}${project}${RESET}"
        current_project="$project"
      fi

      local dirty_color="$GREEN"
      (( dirty_count > 0 )) && dirty_color="$YELLOW"

      printf "  ${CYAN}%-40s${RESET}  ${BOLD}%8s${RESET}  ${dirty_color}%-10s${RESET}  %-8s  %s\n" \
        "$branch" "${ahead} ahead" "$dirty_label" "$age" "\"${description}\""

      found=1
    fi
  done < <(
    for project_root in "${REGISTERED_PROJECTS[@]+"${REGISTERED_PROJECTS[@]}"}"; do
      [[ -d "$project_root/${WORKTREES_DIR}" ]] || continue
      for meta_file in "$project_root/${WORKTREES_DIR}"/*/"$META_FILE"; do
        [[ -f "$meta_file" ]] || continue
        echo "$meta_file"
      done
    done | sort
  )

  if (( found == 0 )); then info "No active worktrees found."; fi
}

# Resolve a branch name, slug, or absolute path to a worktree directory.
# Prints the resolved path to stdout. Calls error() on failure.
_resolve_worktree() {
  local arg="$1"

  # Full path: verify it has a .wt-meta and return directly
  if [[ "$arg" == /* ]]; then
    [[ -f "${arg}/${META_FILE}" ]] || error "No worktree found at: '$arg'"
    echo "$arg"
    return
  fi

  local branch_matches=()
  local slug_matches=()

  while IFS= read -r meta_file; do
    [[ -f "$meta_file" ]] || continue
    local branch slug wt_dir
    branch=$(read_meta "$meta_file" "branch")
    slug=$(read_meta "$meta_file" "slug")
    wt_dir=$(dirname "$meta_file")
    [[ -z "$branch" ]] && continue
    [[ "$branch" == "$arg" ]] && branch_matches+=("$wt_dir")
    [[ "$slug"   == "$arg" ]] && slug_matches+=("$wt_dir")
  done < <(
    for project_root in "${REGISTERED_PROJECTS[@]+"${REGISTERED_PROJECTS[@]}"}"; do
      [[ -d "$project_root/${WORKTREES_DIR}" ]] || continue
      for meta_file in "$project_root/${WORKTREES_DIR}"/*/"$META_FILE"; do
        [[ -f "$meta_file" ]] || continue
        echo "$meta_file"
      done
    done
  )

  # Branch match takes priority over slug match
  local matches=()
  if (( ${#branch_matches[@]} > 0 )); then
    matches=("${branch_matches[@]}")
  else
    matches=("${slug_matches[@]}")
  fi

  case "${#matches[@]}" in
    0) error "No worktree found for: '$arg'" ;;
    1) echo "${matches[0]}" ;;
    *)
      warn "Ambiguous: multiple worktrees match '$arg':"
      for m in "${matches[@]}"; do
        echo "  $m" >&2
      done
      error "Run 'wt list' to see all worktrees"
      ;;
  esac
}

# wt go <branch-or-slug> — navigate to an existing worktree
cmd_go() {
  local arg="${1:-}"
  [[ -z "$arg" ]] && error "Usage: wt go <branch-or-slug>"
  _resolve_worktree "$arg"
}

# Infer and write a .wt-meta for a worktree, merging with any existing fields.
# Args: project_root wt_path [existing_meta_path]
# Existing non-empty fields take precedence over inferred values.
_repair_wt_meta() {
  local project_root="$1" wt_path="$2" existing_meta="${3:-/dev/null}"

  local r_branch r_slug r_project r_project_root r_created r_description r_base

  r_branch=$(git -C "$wt_path" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
  r_slug=$(basename "$wt_path")
  r_project=$(basename "$project_root")
  r_project_root="$project_root"
  r_description="${r_slug//-/ }"
  r_created="unknown"

  if [[ -n "$r_branch" ]]; then
    local _date
    _date=$(git -C "$project_root" reflog show "$r_branch" --format='%ci' 2>/dev/null \
      | head -1 | cut -d' ' -f1 || echo "")
    if [[ -n "$_date" ]]; then r_created="${_date}T00:00:00"; fi
  fi

  # Infer base_branch: non-wt branch with fewest commits ahead of HEAD
  r_base=""
  local _best_count=999999
  while IFS= read -r _b; do
    if [[ "$_b" == "wt/"* || "$_b" == "$r_branch" ]]; then continue; fi
    local _cnt
    _cnt=$(git -C "$wt_path" rev-list --count "${_b}..HEAD" 2>/dev/null || echo 999999)
    if (( _cnt < _best_count )); then _best_count=$_cnt; r_base="$_b"; fi
  done < <(git -C "$project_root" branch 2>/dev/null | sed 's/^[* ]*//')
  [[ -z "$r_base" ]] && r_base="main"

  # Override inferred values with any existing non-empty field values
  local _ev
  _ev=$(grep "^base_branch=" "$existing_meta" 2>/dev/null | head -1 | cut -d= -f2-)
  [[ -n "$_ev" ]] && r_base="$_ev"
  _ev=$(grep "^branch=" "$existing_meta" 2>/dev/null | head -1 | cut -d= -f2-)
  [[ -n "$_ev" ]] && r_branch="$_ev"
  _ev=$(grep "^slug=" "$existing_meta" 2>/dev/null | head -1 | cut -d= -f2-)
  [[ -n "$_ev" ]] && r_slug="$_ev"
  _ev=$(grep "^project=" "$existing_meta" 2>/dev/null | head -1 | cut -d= -f2-)
  [[ -n "$_ev" ]] && r_project="$_ev"
  _ev=$(grep "^project_root=" "$existing_meta" 2>/dev/null | head -1 | cut -d= -f2-)
  [[ -n "$_ev" ]] && r_project_root="$_ev"
  _ev=$(grep "^created=" "$existing_meta" 2>/dev/null | head -1 | cut -d= -f2-)
  [[ -n "$_ev" ]] && r_created="$_ev"
  _ev=$(grep "^description=" "$existing_meta" 2>/dev/null | head -1 | cut -d= -f2-)
  [[ -n "$_ev" ]] && r_description="$_ev"

  cat > "${wt_path}/${META_FILE}" <<EOF
base_branch=${r_base}
created=${r_created}
description=${r_description}
project=${r_project}
project_root=${r_project_root}
slug=${r_slug}
branch=${r_branch}
EOF
}

# wt doctor — scan real repos for state drift and offer to fix
cmd_doctor() {
  local dry_run=0
  for arg in "$@"; do
    case "$arg" in --dry-run) dry_run=1 ;; esac
  done

  local any_project=0
  local total_issues=0

  for project_root in "${REGISTERED_PROJECTS[@]+"${REGISTERED_PROJECTS[@]}"}"; do
    local project_name
    project_name=$(basename "$project_root")
    local issues=0
    local output=""

    # ── Stale registry check ─────────────────────────────────────────────────
    if [[ ! -d "$project_root" ]]; then
      output+="  ${RED}✗${RESET} Stale registry entry: ${BOLD}${project_root}${RESET} (not found on disk)\n"
      if (( dry_run == 1 )); then
        output+="  ${CYAN}→${RESET} [dry-run] Would remove stale registry entry: ${project_root}\n"
      elif confirm "    Remove ${project_root} from registry?"; then
        _unregister_project "$project_root"
        output+="  ${GREEN}✓${RESET} Removed stale registry entry\n"
      fi
      (( issues++ )) || true
      echo -e "\n${BOLD}${CYAN}wt doctor — ${project_name}${RESET}"
      echo -en "$output"
      any_project=1
      (( total_issues += issues )) || true
      continue
    fi

    [[ -d "$project_root/.git" ]] || continue
    [[ -d "${project_root}/${WORKTREES_DIR}" ]] || continue

      # ── Check 1: Orphaned wt/* branches ─────────────────────────────────────
      # A wt/* branch exists but no matching .worktrees/<slug>/ dir.
      # Use fd 5 so stdin stays free for confirm().
      while IFS= read -r branch_line <&5; do
        local branch="${branch_line#  }"  # strip 2-space prefix (non-current branch)
        # "+ " prefix = checked out in another worktree — skip here, handled by check 6
        [[ "$branch" == "+ "* ]] && continue
        branch="${branch#\* }"            # strip "* " prefix (current branch)
        [[ -z "$branch" || "$branch" == *"->"* ]] && continue
        local slug="${branch#wt/}"
        local wt_dir="${project_root}/${WORKTREES_DIR}/${slug}"
        if [[ ! -d "$wt_dir" ]]; then
          output+="  ${RED}✗${RESET} Orphaned branch ${BOLD}${branch}${RESET} (no matching worktree dir)\n"
          if (( dry_run == 1 )); then
            output+="  ${CYAN}→${RESET} [dry-run] Would delete branch ${branch}\n"
          elif confirm "    Delete branch ${branch}?"; then
            git -C "$project_root" branch -D "$branch" >&2 \
              && output+="  ${GREEN}✓${RESET} Deleted ${branch}\n" \
              || output+="  ${YELLOW}⚠${RESET} Could not delete ${branch}\n"
          fi
          (( issues++ )) || true
        fi
      done 5< <(git -C "$project_root" branch --list 'wt/*' 2>/dev/null)

      # ── Check 2: Orphaned worktree dirs ─────────────────────────────────────
      # A .worktrees/<slug>/ dir exists but isn't a registered git worktree.
      if [[ -d "${project_root}/${WORKTREES_DIR}" ]]; then
        for wt_dir in "${project_root}/${WORKTREES_DIR}"/*/; do
          [[ -d "$wt_dir" ]] || continue
          local slug
          slug=$(basename "$wt_dir")
          if ! git -C "$project_root" worktree list --porcelain 2>/dev/null \
              | grep -qF "worktree ${wt_dir%/}"; then
            output+="  ${RED}✗${RESET} Orphaned worktree dir ${BOLD}.worktrees/${slug}${RESET} (not a registered git worktree)\n"
            if (( dry_run == 1 )); then
              output+="  ${CYAN}→${RESET} [dry-run] Would remove .worktrees/${slug}\n"
            elif confirm "    Remove dir .worktrees/${slug}?"; then
              rm -rf "$wt_dir" \
                && output+="  ${GREEN}✓${RESET} Removed .worktrees/${slug}\n" \
                || output+="  ${YELLOW}⚠${RESET} Could not remove .worktrees/${slug}\n"
            fi
            (( issues++ )) || true
          fi
        done
      fi

      # ── Check 2b: Missing .wt-meta in registered worktrees ──────────────────
      # A registered git worktree exists but has no .wt-meta file.
      while IFS= read -r _wt_line <&5; do
        if [[ "$_wt_line" == worktree\ * ]]; then
          local _wt_path="${_wt_line#worktree }"
          [[ "$_wt_path" == "$project_root" ]] && continue
          [[ ! -d "$_wt_path" ]] && continue  # stale — handled by check 6
          if [[ ! -f "${_wt_path}/${META_FILE}" ]]; then
            local _wt_slug
            _wt_slug=$(basename "$_wt_path")
            output+="  ${RED}✗${RESET} Missing ${META_FILE} in ${BOLD}.worktrees/${_wt_slug}${RESET}\n"
            if (( dry_run == 1 )); then
              output+="  ${CYAN}→${RESET} [dry-run] Would repair ${META_FILE} for .worktrees/${_wt_slug}\n"
            elif confirm "    Repair ${META_FILE} for .worktrees/${_wt_slug}?"; then
              _repair_wt_meta "$project_root" "$_wt_path" "/dev/null" || true
              output+="  ${GREEN}✓${RESET} Repaired ${META_FILE} for .worktrees/${_wt_slug}\n"
            fi
            (( issues++ )) || true
          fi
        fi
      done 5< <(git -C "$project_root" worktree list --porcelain 2>/dev/null)

      # ── Check 3: Corrupt .wt-meta ────────────────────────────────────────────
      if [[ -d "${project_root}/${WORKTREES_DIR}" ]]; then
        for meta_file in "${project_root}/${WORKTREES_DIR}"/*/"${META_FILE}"; do
          [[ -f "$meta_file" ]] || continue
          local m_base m_branch m_slug
          m_base=$(read_meta "$meta_file" "base_branch")
          m_branch=$(read_meta "$meta_file" "branch")
          m_slug=$(read_meta "$meta_file" "slug")
          if [[ -z "$m_base" || -z "$m_branch" || -z "$m_slug" ]]; then
            local wt_name
            wt_name=$(basename "$(dirname "$meta_file")")
            output+="  ${RED}✗${RESET} Corrupt ${META_FILE} in ${BOLD}.worktrees/${wt_name}${RESET} (missing: base_branch/branch/slug)\n"
            local _corrupt_wt_path
            _corrupt_wt_path=$(dirname "$meta_file")
            if (( dry_run == 1 )); then
              output+="  ${CYAN}→${RESET} [dry-run] Would repair ${META_FILE} for .worktrees/${wt_name}\n"
            elif confirm "    Repair ${META_FILE} for .worktrees/${wt_name}?"; then
              _repair_wt_meta "$project_root" "$_corrupt_wt_path" "$meta_file" || true
              output+="  ${GREEN}✓${RESET} Repaired ${META_FILE} for .worktrees/${wt_name}\n"
            else
              output+="    Fix manually: edit ${meta_file}\n"
            fi
            (( issues++ )) || true
          fi
        done
      fi

      # ── Check 4: Missing .worktrees/ in info/exclude ─────────────────────────
      local exclude_file="${project_root}/.git/info/exclude"
      if ! grep -qxF ".worktrees/" "$exclude_file" 2>/dev/null; then
        output+="  ${RED}✗${RESET} ${BOLD}.worktrees/${RESET} missing from .git/info/exclude\n"
        if (( dry_run == 1 )); then
          output+="  ${CYAN}→${RESET} [dry-run] Would add .worktrees/ to info/exclude\n"
        elif confirm "    Add .worktrees/ to info/exclude?"; then
          mkdir -p "${project_root}/.git/info"
          echo ".worktrees/" >> "$exclude_file" \
            && output+="  ${GREEN}✓${RESET} Added .worktrees/ to info/exclude\n" \
            || output+="  ${YELLOW}⚠${RESET} Could not write to info/exclude\n"
        fi
        (( issues++ )) || true
      fi

      # ── Check 5: Missing .wt-meta in info/exclude ───────────────────────────
      if ! grep -qxF ".wt-meta" "$exclude_file" 2>/dev/null; then
        output+="  ${RED}✗${RESET} ${BOLD}.wt-meta${RESET} missing from .git/info/exclude\n"
        if (( dry_run == 1 )); then
          output+="  ${CYAN}→${RESET} [dry-run] Would add .wt-meta to info/exclude\n"
        elif confirm "    Add .wt-meta to info/exclude?"; then
          mkdir -p "${project_root}/.git/info"
          echo ".wt-meta" >> "$exclude_file" \
            && output+="  ${GREEN}✓${RESET} Added .wt-meta to info/exclude\n" \
            || output+="  ${YELLOW}⚠${RESET} Could not write to info/exclude\n"
        fi
        (( issues++ )) || true
      fi

      # ── Check 6: Stale git worktree registrations ────────────────────────────
      local stale_wts=()
      while IFS= read -r line <&5; do
        if [[ "$line" == worktree\ * ]]; then
          local wt_path="${line#worktree }"
          [[ "$wt_path" == "$project_root" ]] && continue
          [[ ! -d "$wt_path" ]] && stale_wts+=("$wt_path")
        fi
      done 5< <(git -C "$project_root" worktree list --porcelain 2>/dev/null)

      if (( ${#stale_wts[@]} > 0 )); then
        output+="  ${RED}✗${RESET} ${#stale_wts[@]} stale git worktree registration(s) (dir removed without pruning)\n"
        for sp in "${stale_wts[@]}"; do
          output+="    ${sp}\n"
        done
        if (( dry_run == 1 )); then
          output+="  ${CYAN}→${RESET} [dry-run] Would prune stale registrations\n"
        elif confirm "    Run 'git worktree prune' and delete stale wt/* branches?"; then
          git -C "$project_root" worktree prune >&2
          for sp in "${stale_wts[@]}"; do
            local stale_slug
            stale_slug=$(basename "$sp")
            git -C "$project_root" branch -D "wt/${stale_slug}" >&2 2>/dev/null || true
          done
          output+="  ${GREEN}✓${RESET} Pruned stale registrations\n"
        fi
        (( issues++ )) || true
      fi

    # ── Print section ─────────────────────────────────────────────────────────
    if (( issues > 0 )) || [[ "$any_project" -eq 0 ]]; then
      echo -e "\n${BOLD}${CYAN}wt doctor — ${project_name}${RESET}"
      if (( issues == 0 )); then
        echo -e "  ${GREEN}✓${RESET} all good"
      else
        echo -en "$output"
      fi
      any_project=1
    fi
    (( total_issues += issues )) || true

  done

  if (( any_project == 0 )); then
    info "No projects found in registry."
    return 0
  fi

  echo ""
  if (( total_issues == 0 )); then
    success "All projects healthy."
  else
    warn "${total_issues} issue(s) found."
  fi
}

# ─── Entry Point ─────────────────────────────────────────────────────────────

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    new)            cmd_new "$@" ;;
    finish)         cmd_finish "$@" ;;
    sync)           cmd_sync "$@" ;;
    retarget)       cmd_retarget "$@" ;;
    abandon)        cmd_abandon "$@" ;;
    pr)             cmd_pr "$@" ;;
    status|st)      cmd_status "$@" ;;
    list|ls)        cmd_list "$@" ;;
    go)             cmd_go "$@" ;;
    doctor)         cmd_doctor "$@" ;;
    help|-h|--help) cmd_help ;;
    *)              error "Unknown command: '$cmd'. Run 'wt help' for usage." ;;
  esac
}

main "$@"
