#!/usr/bin/env bash
# =============================================================================
# wt — Git Worktree Lifecycle Tool
# =============================================================================
#
# Automates creating, tracking, rebasing, and cleaning up git worktrees for
# parallel development workflows.
#
# COMMANDS
#   wt new [project] "<description>"   Create a worktree with auto-named branch
#   wt finish                          Rebase + fast-forward into base, clean up
#   wt sync                            Rebase onto latest base branch (from origin)
#   wt drop                            Abandon worktree without merging, clean up
#   wt list                            Show all worktrees across projects
#   wt help                            Show this help
#
# INSTALLATION
#   1. Run ./install.sh  (copies bin/wt to ~/.local/bin/wt)
#      Or manually: cp bin/wt ~/.local/bin/wt && chmod +x ~/.local/bin/wt
#   2. Add the shell wrapper to ~/.zshrc or ~/.bashrc so that wt new/finish/drop
#      cd your shell into the new directory:
#
#      # zsh (~/.zshrc):
#      function wt() {
#        if [[ "$1" == "new" || "$1" == "finish" || "$1" == "done" || "$1" == "drop" ]]; then
#          local dir
#          dir=$(command wt "$@") && [[ -n "$dir" ]] && cd "$dir"
#        else
#          command wt "$@"
#        fi
#      }
#
#      # bash (~/.bashrc):
#      wt() {    # identical syntax, just a different file
#        if [[ "$1" == "new" || "$1" == "finish" || "$1" == "done" || "$1" == "drop" ]]; then
#          local dir
#          dir=$(command wt "$@") && [[ -n "$dir" ]] && cd "$dir"
#        else
#          command wt "$@"
#        fi
#      }
#
# CONFIGURATION
#   Set WT_SEARCH_PATHS (colon-separated) or create ~/.config/wt/config
#   (one directory per line). See README for details.
#
# HOW IT WORKS
#   - Worktrees live at <project>/.worktrees/<slug>/
#   - Branch name: wt/<slug> (auto-generated from description)
#   - .wt-meta stores key=value pairs (no quoting, read with cut -d= -f2-)
#   - `wt finish` reads .wt-meta, safety-checks, rebases onto base, fast-forwards, removes worktree+branch
#   - `wt drop` abandons the worktree without merging
#
# =============================================================================

set -euo pipefail

# ─── Constants ───────────────────────────────────────────────────────────────

BRANCH_PREFIX="wt"
WORKTREES_DIR=".worktrees"
META_FILE=".wt-meta"

# ─── Config: search paths ────────────────────────────────────────────────────
# Load PROJECT_SEARCH_PATHS from (in order of precedence):
#   1. WT_SEARCH_PATHS env var (colon-separated, like PATH)
#   2. ~/.config/wt/config file (one path per line, blank lines ignored)
#   3. Default: ~/src ~/projects ~/repos ~/code

_load_search_paths() {
  if [[ -n "${WT_SEARCH_PATHS:-}" ]]; then
    IFS=':' read -ra PROJECT_SEARCH_PATHS <<< "$WT_SEARCH_PATHS"
  elif [[ -f "${XDG_CONFIG_HOME:-$HOME/.config}/wt/config" ]]; then
    PROJECT_SEARCH_PATHS=()
    while IFS= read -r line || [[ -n "$line" ]]; do
      [[ -z "$line" || "$line" == "#"* ]] && continue
      PROJECT_SEARCH_PATHS+=("$line")
    done < "${XDG_CONFIG_HOME:-$HOME/.config}/wt/config"
  else
    PROJECT_SEARCH_PATHS=("$HOME/src" "$HOME/projects" "$HOME/repos" "$HOME/code")
  fi
}

_load_search_paths

# ─── Colors ──────────────────────────────────────────────────────────────────
# Check stdout (fd 1) — `wt list` outputs to stdout, and that's the only
# command where piping matters. new/done write UI to stderr, which is fine.

if [[ -t 1 ]]; then
  RED='\033[0;31m'
  YELLOW='\033[0;33m'
  GREEN='\033[0;32m'
  CYAN='\033[0;36m'
  BOLD='\033[1m'
  RESET='\033[0m'
else
  RED='' YELLOW='' GREEN='' CYAN='' BOLD='' RESET=''
fi

# ─── Helpers ─────────────────────────────────────────────────────────────────

# All UI output goes to stderr — stdout is reserved for returning paths to the
# shell wrapper for `cd`.
info()    { echo -e "${CYAN}→${RESET} $*" >&2; }
success() { echo -e "${GREEN}✓${RESET} $*" >&2; }
warn()    { echo -e "${YELLOW}⚠${RESET} $*" >&2; }
error()   { echo -e "${RED}✗${RESET} $*" >&2; exit 1; }

confirm() {
  local prompt="$1"
  local response
  echo -en "${BOLD}${prompt}${RESET} [y/N] " >&2
  read -r response
  [[ "$response" =~ ^[Yy]$ ]]
}

# Slugify a description string:
# "Fix the Sidebar Overflow Bug!" → "fix-the-sidebar-overflow-bug"
slugify() {
  echo "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | sed 's/[^a-z0-9 -]//g' \
    | tr -s ' ' '-' \
    | cut -c1-50 \
    | sed 's/-$//'
}

# Find a project directory by name — verifies it's a git repo
find_project() {
  local name="$1"
  for base in "${PROJECT_SEARCH_PATHS[@]}"; do
    local candidate="$base/$name"
    # Accept both git directories (.git dir) and worktrees (.git file)
    if [[ -d "$candidate/.git" ]] || [[ -f "$candidate/.git" ]]; then
      echo "$candidate"
      return 0
    fi
  done
  return 1
}

# Get the main worktree path (the first entry in `git worktree list`)
get_main_worktree() {
  git worktree list --porcelain 2>/dev/null \
    | awk '/^worktree / { if (first=="") first=$2 } END { print first }'
}

# Safely read a single key from a .wt-meta file
# Format: key=value (plain, no quoting — values must not contain newlines)
read_meta() {
  local file="$1" key="$2"
  grep "^${key}=" "$file" 2>/dev/null | head -1 | cut -d= -f2- || true
}

# Check if a tmux session exists
tmux_session_exists() {
  tmux has-session -t "$1" 2>/dev/null
}

# Returns true if a Claude Code (or custom editor) process is running in the session.
# Hook: override this function for custom editor detection.
# Default: always returns false (no active-editor check).
claude_running_in_session() {
  false
}

# Human-readable age from a YYYY-MM-DDTHH:MM:SS timestamp
# Supports both GNU date (Linux) and BSD date (macOS).
human_age() {
  local ts="$1"
  local now then diff
  now=$(date +%s)
  # Try GNU date first, fall back to BSD date
  then=$(date -d "$ts" +%s 2>/dev/null) \
    || then=$(date -j -f "%Y-%m-%dT%H:%M:%S" "$ts" +%s 2>/dev/null) \
    || then="$now"
  diff=$(( now - then ))
  if   (( diff < 3600   )); then echo "$(( diff / 60 ))m ago"
  elif (( diff < 86400  )); then echo "$(( diff / 3600 ))h ago"
  elif (( diff < 604800 )); then echo "$(( diff / 86400 ))d ago"
  else                          echo "$(( diff / 604800 ))w ago"
  fi
}

# ─── Commands ────────────────────────────────────────────────────────────────

cmd_help() {
  cat <<'HELP'
wt — Git Worktree Lifecycle Tool

USAGE
  wt new [project] "<description>"   Create a worktree with auto-named branch
  wt finish                          Rebase onto base, fast-forward, clean up
  wt sync                            Rebase onto latest base branch (from origin)
  wt drop                            Abandon worktree without merging, clean up
  wt list                            Show all active worktrees across projects
  wt doctor                          Check for orphaned branches/dirs, fix interactively
  wt help                            Show this help

EXAMPLES
  # From inside a project dir:
  wt new "fix the sidebar overflow bug"

  # From anywhere, specifying project by name:
  wt new <project> "add dark mode toggle"

  # Rebase onto base and clean up (run from inside a worktree):
  wt finish

  # Rebase worktree onto latest base (run from inside a worktree):
  wt sync

  # Abandon a dead-end worktree without merging:
  wt drop

  # List all active worktrees:
  wt list

NOTES
  • Worktrees are created at <project>/.worktrees/<slug>/
  • Branch names: wt/<slug> (auto-generated from your description)
  • After `wt new`, your shell cd's into the new worktree automatically
  • After `wt finish`, your shell cd's back to the main worktree
  • Use `wt sync` to keep long-lived worktrees current with the base branch
  • Configure search paths: export WT_SEARCH_PATHS=~/src:~/projects
  • Or create ~/.config/wt/config with one directory per line
HELP
}

# wt new [project] "<description>"
cmd_new() {
  local project_arg=""
  local description=""

  case $# in
    0) error "Usage: wt new [project] \"<description>\"" ;;
    1) description="$1" ;;
    2) project_arg="$1"; description="$2" ;;
    *) error "Usage: wt new [project] \"<description>\"" ;;
  esac

  [[ -z "$description" ]] && error "Description cannot be empty"

  # Resolve project root
  local project_root
  if [[ -n "$project_arg" ]]; then
    project_root=$(find_project "$project_arg") \
      || error "Project '$project_arg' not found (or not a git repo) in ${PROJECT_SEARCH_PATHS[*]}"
  else
    project_root=$(git rev-parse --show-toplevel 2>/dev/null) \
      || error "Not inside a git repository. Run from inside a project or pass a project name."
  fi

  # If inside a worktree (not main checkout), redirect to actual project root.
  # A worktree has a .git *file*; main checkout has a .git *directory*.
  if [[ -f "${project_root}/.git" ]]; then
    project_root=$(get_main_worktree) \
      || error "Could not resolve main worktree path"
    info "Detected worktree context — using main checkout: ${project_root}"
  fi

  local project_name
  project_name=$(basename "$project_root")

  local slug
  slug=$(slugify "$description")
  [[ -z "$slug" ]] && error "Could not generate a slug from: '$description'"

  local branch="${BRANCH_PREFIX}/${slug}"
  local worktree_path="${project_root}/${WORKTREES_DIR}/${slug}"

  # Conflict checks
  [[ -d "$worktree_path" ]] && error "Worktree already exists: $worktree_path"
  git -C "$project_root" rev-parse --verify "$branch" &>/dev/null \
    && error "Branch already exists: $branch"

  # Record current branch as merge target
  local base_branch
  base_branch=$(git -C "$project_root" symbolic-ref --short HEAD 2>/dev/null) \
    || error "Could not determine current branch in $project_root"

  local created
  created=$(date '+%Y-%m-%dT%H:%M:%S')

  mkdir -p "${project_root}/${WORKTREES_DIR}"

  # Exclude .worktrees/ from git status via info/exclude (repo-local, not committed).
  # project_root is always the main worktree here (resolved above), so .git is a directory.
  mkdir -p "${project_root}/.git/info"
  if ! grep -qxF ".worktrees/" "${project_root}/.git/info/exclude" 2>/dev/null; then
    echo ".worktrees/" >> "${project_root}/.git/info/exclude"
  fi

  info "Creating worktree: ${BOLD}${project_name}/.worktrees/${slug}${RESET}"
  info "Branch: ${BOLD}${branch}${RESET} (base: ${base_branch})"

  git -C "$project_root" worktree add "$worktree_path" -b "$branch" >&2 \
    || error "Failed to create git worktree"

  # Write .wt-meta — plain key=value, no quoting.
  # Values must not contain newlines (descriptions are single-line by design).
  # Read with read_meta() using cut -d= -f2-, no eval.
  cat > "${worktree_path}/${META_FILE}" <<EOF
base_branch=${base_branch}
created=${created}
description=${description}
project=${project_name}
project_root=${project_root}
slug=${slug}
branch=${branch}
EOF

  # Exclude .wt-meta from git status.
  # info/exclude lives under GIT_COMMON_DIR (the main .git dir, shared by all worktrees).
  # We only append if not already present to avoid duplicate entries.
  local common_dir
  common_dir=$(git -C "$worktree_path" rev-parse --git-common-dir 2>/dev/null || echo "")
  if [[ -n "$common_dir" ]]; then
    mkdir -p "${common_dir}/info"
    if ! grep -qxF ".wt-meta" "${common_dir}/info/exclude" 2>/dev/null; then
      echo ".wt-meta" >> "${common_dir}/info/exclude"
    fi
  fi

  success "Worktree created: ${worktree_path}"

  # Detect package manager and prompt for dep install
  local pm=""
  if [[ -f "${worktree_path}/package.json" ]]; then
    if   [[ -f "${worktree_path}/pnpm-lock.yaml" ]]; then pm="pnpm"
    elif [[ -f "${worktree_path}/yarn.lock"       ]]; then pm="yarn"
    else                                                   pm="npm"
    fi
  elif [[ -f "${worktree_path}/uv.lock"          ]]; then pm="uv"
  elif [[ -f "${worktree_path}/poetry.lock"       ]]; then pm="poetry"
  elif [[ -f "${worktree_path}/requirements.txt"  ]]; then pm="pip"
  elif [[ -f "${worktree_path}/pyproject.toml"    ]]; then pm="pip"
  fi

  if [[ -n "$pm" ]]; then
    warn "Worktrees don't share node_modules/venv. You'll need: ${BOLD}${pm} install${RESET}"
    if confirm "Run '${pm} install' now?"; then
      info "Running ${pm} install..."
      (cd "$worktree_path" && "$pm" install) \
        || warn "${pm} install failed — run it manually."
      success "Dependencies installed"
    fi
  fi

  # Return path on stdout for shell wrapper to cd into
  echo "$worktree_path"
}

# wt finish — rebase worktree onto base, fast-forward, clean up
cmd_finish() {
  local repo_root
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null) \
    || error "Not inside a git repository"

  [[ -d "${repo_root}/.git" ]] \
    && error "You are in the main checkout, not a worktree."

  local meta_file="${repo_root}/${META_FILE}"
  [[ -f "$meta_file" ]] \
    || error "No ${META_FILE} found. Was this worktree created with 'wt new'?"

  local base_branch description project project_root slug branch
  base_branch=$(read_meta "$meta_file" "base_branch")
  description=$(read_meta "$meta_file" "description")
  project=$(read_meta "$meta_file" "project")
  project_root=$(read_meta "$meta_file" "project_root")
  slug=$(read_meta "$meta_file" "slug")
  branch=$(read_meta "$meta_file" "branch")

  [[ -z "$base_branch" || -z "$branch" ]] \
    && error "Corrupt .wt-meta — missing required fields"

  info "Worktree: ${BOLD}${branch}${RESET}"
  info "Description: ${description}"
  info "Base branch: ${BOLD}${base_branch}${RESET}"

  # Safety: uncommitted changes
  [[ -n "$(git status --porcelain)" ]] \
    && error "Uncommitted changes present. Commit or stash before 'wt finish'."

  # Safety: editor still running (tmux only; override claude_running_in_session() to customize)
  if [[ -n "${TMUX:-}" ]]; then
    local session_name="${project}/${slug}"
    session_name="${session_name//./_}"
    if tmux_session_exists "$session_name" && claude_running_in_session "$session_name"; then
      warn "Editor is still running in session '${session_name}'"
      confirm "Proceed anyway?" || exit 0
    fi
  fi

  confirm "Rebase ${BOLD}${branch}${RESET} onto ${BOLD}${base_branch}${RESET} and fast-forward?" \
    || { info "Aborted."; exit 0; }

  local main_wt
  main_wt=$(get_main_worktree)
  [[ -z "$main_wt" ]] && error "Could not determine main worktree path"

  # Fetch remote base branch if a remote exists (best-effort, ignore failure)
  git fetch origin "${base_branch}" >&2 2>/dev/null || true

  info "Rebasing ${branch} onto ${base_branch}..."

  # Rebase onto base — produces a linear history regardless of base drift
  local rebase_err
  if ! rebase_err=$(git rebase -- "${base_branch}" 2>&1); then
    git rebase --abort 2>/dev/null || true
    warn "Rebase conflict. Aborted."
    echo -e "Resolve manually:" >&2
    echo -e "  cd ${repo_root} && git rebase ${base_branch}" >&2
    echo -e "  # resolve conflicts, then: wt finish" >&2
    exit 1
  fi
  success "Rebase successful"

  # Fast-forward base to the rebased tip.
  # Strategy 1: from within this worktree (works when base_branch is NOT checked out here)
  local ff_err
  if ff_err=$(git fetch . "HEAD:${base_branch}" 2>&1); then
    success "Fast-forward successful"
  else
    # Strategy 2: base_branch is checked out in the main worktree — use --ff-only there
    local main_branch
    main_branch=$(git -C "$main_wt" symbolic-ref --short HEAD 2>/dev/null || echo "")
    if [[ "$main_branch" == "$base_branch" ]]; then
      if git -C "$main_wt" merge --ff-only "$branch" >&2; then
        success "Fast-forward successful (from main worktree)"
      else
        warn "Fast-forward failed: ${ff_err}"
        echo -e "Resolve manually:" >&2
        echo -e "  cd ${main_wt} && git merge --ff-only ${branch}" >&2
        echo -e "  # then: git worktree remove ${repo_root} && git branch -D ${branch}" >&2
        exit 1
      fi
    else
      warn "Could not fast-forward: '${base_branch}' is not checked out in main worktree."
      echo -e "Resolve manually:" >&2
      echo -e "  cd ${main_wt} && git checkout ${base_branch} && git merge --ff-only ${branch}" >&2
      echo -e "  git worktree remove ${repo_root} && git branch -D ${branch}" >&2
      exit 1
    fi
  fi

  _cleanup_worktree "$repo_root" "$branch" "$main_wt" "$project" "$slug" "force"

  success "Done! Worktree rebased, integrated, and cleaned up."
  echo "$main_wt"
}

# wt sync — rebase worktree branch onto latest base (from origin)
cmd_sync() {
  local repo_root
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null) \
    || error "Not inside a git repository"

  [[ -d "${repo_root}/.git" ]] \
    && error "You are in the main checkout, not a worktree."

  local meta_file="${repo_root}/${META_FILE}"
  [[ -f "$meta_file" ]] \
    || error "No ${META_FILE} found. Was this worktree created with 'wt new'?"

  local base_branch description branch
  base_branch=$(read_meta "$meta_file" "base_branch")
  description=$(read_meta "$meta_file" "description")
  branch=$(read_meta "$meta_file" "branch")

  [[ -z "$base_branch" || -z "$branch" ]] \
    && error "Corrupt .wt-meta — missing required fields"

  info "Worktree: ${BOLD}${branch}${RESET}"
  info "Description: ${description}"
  info "Base branch: ${BOLD}${base_branch}${RESET}"

  # Safety: uncommitted changes
  [[ -n "$(git status --porcelain)" ]] \
    && error "Uncommitted changes present. Commit or stash before 'wt sync'."

  # Fetch remote base branch to get latest (warn on failure, still try rebase)
  info "Fetching origin/${base_branch}..."
  git fetch origin "${base_branch}" >&2 2>/dev/null \
    || warn "Could not fetch origin/${base_branch} — will rebase onto local ref"

  # Prefer origin/<base_branch> (ensures we get remote state); fall back to local
  local rebase_target="origin/${base_branch}"
  if ! git rev-parse --verify "${rebase_target}" &>/dev/null; then
    rebase_target="${base_branch}"
    warn "No remote-tracking branch ${rebase_target} — using local ${base_branch}"
  fi

  info "Rebasing ${branch} onto ${rebase_target}..."

  local rebase_err
  if ! rebase_err=$(git rebase "${rebase_target}" 2>&1); then
    git rebase --abort 2>/dev/null || true
    warn "Rebase conflict. Aborted."
    echo -e "Resolve manually:" >&2
    echo -e "  cd ${repo_root} && git rebase ${rebase_target}" >&2
    echo -e "  # resolve conflicts, then: wt sync" >&2
    exit 1
  fi

  success "Synced — ${branch} is up to date with ${rebase_target}"
}

# wt drop — abandon worktree without merging
cmd_drop() {
  local repo_root
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null) \
    || error "Not inside a git repository"

  [[ -d "${repo_root}/.git" ]] \
    && error "You are in the main checkout, not a worktree."

  local meta_file="${repo_root}/${META_FILE}"
  [[ -f "$meta_file" ]] \
    || error "No ${META_FILE} found. Was this worktree created with 'wt new'?"

  local description project slug branch
  description=$(read_meta "$meta_file" "description")
  project=$(read_meta "$meta_file" "project")
  slug=$(read_meta "$meta_file" "slug")
  branch=$(read_meta "$meta_file" "branch")

  [[ -z "$branch" ]] && error "Corrupt .wt-meta — missing branch field"

  info "Worktree: ${BOLD}${branch}${RESET}"
  info "Description: ${description}"
  warn "This will DELETE the worktree and branch WITHOUT merging. Work will be lost."

  # Safety: uncommitted changes
  if [[ -n "$(git status --porcelain)" ]]; then
    warn "There are uncommitted changes in this worktree."
    confirm "Drop anyway (changes will be lost)?" || exit 0
  fi

  # Safety: editor still running (tmux only; override claude_running_in_session() to customize)
  if [[ -n "${TMUX:-}" ]]; then
    local session_name="${project}/${slug}"
    session_name="${session_name//./_}"
    if tmux_session_exists "$session_name" && claude_running_in_session "$session_name"; then
      warn "Editor is still running in session '${session_name}'"
      confirm "Proceed anyway?" || exit 0
    fi
  fi

  confirm "Drop ${BOLD}${branch}${RESET}? (no merge)" || { info "Aborted."; exit 0; }

  local main_wt
  main_wt=$(get_main_worktree)
  [[ -z "$main_wt" ]] && error "Could not determine main worktree path"

  _cleanup_worktree "$repo_root" "$branch" "$main_wt" "$project" "$slug" "force"

  success "Dropped. Worktree removed, branch deleted (unmerged)."
  echo "$main_wt"
}

# Shared cleanup: remove worktree dir, delete branch, kill tmux session
# Args: repo_root branch main_wt project slug [force]
_cleanup_worktree() {
  local repo_root="$1" branch="$2" main_wt="$3" project="$4" slug="$5"
  local force="${6:-}"

  info "Removing worktree..."
  git -C "$main_wt" worktree remove "$repo_root" --force >&2 \
    || warn "Could not auto-remove worktree dir. Run: rm -rf ${repo_root}"

  info "Deleting branch ${branch}..."
  if [[ -n "$force" ]]; then
    git -C "$main_wt" branch -D "$branch" >&2 \
      || warn "Could not force-delete branch ${branch}"
  else
    git -C "$main_wt" branch -d "$branch" >&2 \
      || warn "Could not delete branch ${branch}"
  fi

  # Kill tmux session — escape our own session first if needed
  if [[ -n "${TMUX:-}" ]]; then
    local session_name="${project}/${slug}"
    session_name="${session_name//./_}"
    if tmux_session_exists "$session_name"; then
      local current_session
      current_session=$(tmux display-message -p '#S' 2>/dev/null || echo "")
      if [[ "$current_session" == "$session_name" ]]; then
        if tmux_session_exists "$project"; then
          tmux switch-client -t "$project"
        elif tmux_session_exists "${project//./_}"; then
          tmux switch-client -t "${project//./_}"
        else
          warn "Can't kill own session '${session_name}' — no other session to switch to. Kill manually."
          return 0
        fi
      fi
      info "Killing tmux session '${session_name}'..."
      tmux kill-session -t "$session_name" 2>/dev/null || true
    fi
  fi
}

# wt list — show all active worktrees across projects
cmd_list() {
  local found=0
  local current_project=""

  while IFS= read -r meta_file; do
    [[ -f "$meta_file" ]] || continue

    local wt_dir
    wt_dir=$(dirname "$meta_file")

    local base_branch description project created branch
    base_branch=$(read_meta "$meta_file" "base_branch")
    description=$(read_meta "$meta_file" "description")
    project=$(read_meta "$meta_file" "project")
    created=$(read_meta "$meta_file" "created")
    branch=$(read_meta "$meta_file" "branch")

    [[ -z "$branch" ]] && continue

    if git -C "$wt_dir" rev-parse --git-dir &>/dev/null; then
      local dirty_count dirty_label
      dirty_count=$(git -C "$wt_dir" status --porcelain 2>/dev/null | wc -l | tr -d ' ')
      if (( dirty_count > 0 )); then dirty_label="${dirty_count} dirty"; else dirty_label="clean"; fi

      local ahead
      ahead=$(git -C "$wt_dir" rev-list --count "${base_branch}..HEAD" 2>/dev/null || echo 0)

      local age="?"
      [[ -n "$created" ]] && age=$(human_age "$created")

      if [[ "$project" != "$current_project" ]]; then
        [[ -n "$current_project" ]] && echo ""
        echo -e "${BOLD}${project}${RESET}"
        current_project="$project"
      fi

      local dirty_color="$GREEN"
      (( dirty_count > 0 )) && dirty_color="$YELLOW"

      printf "  ${CYAN}%-40s${RESET}  ${BOLD}%8s${RESET}  ${dirty_color}%-10s${RESET}  %-8s  %s\n" \
        "$branch" "${ahead} ahead" "$dirty_label" "$age" "\"${description}\""

      found=1
    fi
  done < <(
    for base in "${PROJECT_SEARCH_PATHS[@]}"; do
      find "$base" -maxdepth 4 -name "$META_FILE" -path "*/${WORKTREES_DIR}/*" 2>/dev/null
    done | sort
  )

  if (( found == 0 )); then info "No active worktrees found."; fi
}

# wt doctor — scan real repos for state drift and offer to fix
cmd_doctor() {
  local any_project=0
  local total_issues=0

  for base in "${PROJECT_SEARCH_PATHS[@]}"; do
    [[ -d "$base" ]] || continue

    # Use fd 4 for the outer project loop so stdin (fd 0) stays free for confirm()
    while IFS= read -r project_root <&4; do
      [[ -d "$project_root/.git" ]] || continue
      [[ -d "${project_root}/${WORKTREES_DIR}" ]] || continue

      local project_name
      project_name=$(basename "$project_root")
      local issues=0
      local output=""

      # ── Check 1: Orphaned wt/* branches ─────────────────────────────────────
      # A wt/* branch exists but no matching .worktrees/<slug>/ dir.
      # Use fd 5 so stdin stays free for confirm().
      while IFS= read -r branch_line <&5; do
        local branch="${branch_line#  }"  # strip 2-space prefix (non-current branch)
        # "+ " prefix = checked out in another worktree — skip here, handled by check 6
        [[ "$branch" == "+ "* ]] && continue
        branch="${branch#\* }"            # strip "* " prefix (current branch)
        [[ -z "$branch" || "$branch" == *"->"* ]] && continue
        local slug="${branch#wt/}"
        local wt_dir="${project_root}/${WORKTREES_DIR}/${slug}"
        if [[ ! -d "$wt_dir" ]]; then
          output+="  ${RED}✗${RESET} Orphaned branch ${BOLD}${branch}${RESET} (no matching worktree dir)\n"
          if confirm "    Delete branch ${branch}?"; then
            git -C "$project_root" branch -D "$branch" >&2 \
              && output+="  ${GREEN}✓${RESET} Deleted ${branch}\n" \
              || output+="  ${YELLOW}⚠${RESET} Could not delete ${branch}\n"
          fi
          (( issues++ )) || true
        fi
      done 5< <(git -C "$project_root" branch --list 'wt/*' 2>/dev/null)

      # ── Check 2: Orphaned worktree dirs ─────────────────────────────────────
      # A .worktrees/<slug>/ dir exists but isn't a registered git worktree.
      if [[ -d "${project_root}/${WORKTREES_DIR}" ]]; then
        for wt_dir in "${project_root}/${WORKTREES_DIR}"/*/; do
          [[ -d "$wt_dir" ]] || continue
          local slug
          slug=$(basename "$wt_dir")
          if ! git -C "$project_root" worktree list --porcelain 2>/dev/null \
              | grep -q "^worktree ${wt_dir%/}$"; then
            output+="  ${RED}✗${RESET} Orphaned worktree dir ${BOLD}.worktrees/${slug}${RESET} (not a registered git worktree)\n"
            if confirm "    Remove dir .worktrees/${slug}?"; then
              rm -rf "$wt_dir" \
                && output+="  ${GREEN}✓${RESET} Removed .worktrees/${slug}\n" \
                || output+="  ${YELLOW}⚠${RESET} Could not remove .worktrees/${slug}\n"
            fi
            (( issues++ )) || true
          fi
        done
      fi

      # ── Check 3: Corrupt .wt-meta ────────────────────────────────────────────
      if [[ -d "${project_root}/${WORKTREES_DIR}" ]]; then
        for meta_file in "${project_root}/${WORKTREES_DIR}"/*/"${META_FILE}"; do
          [[ -f "$meta_file" ]] || continue
          local m_base m_branch m_slug
          m_base=$(read_meta "$meta_file" "base_branch")
          m_branch=$(read_meta "$meta_file" "branch")
          m_slug=$(read_meta "$meta_file" "slug")
          if [[ -z "$m_base" || -z "$m_branch" || -z "$m_slug" ]]; then
            local wt_name
            wt_name=$(basename "$(dirname "$meta_file")")
            output+="  ${RED}✗${RESET} Corrupt ${META_FILE} in ${BOLD}.worktrees/${wt_name}${RESET} (missing: base_branch/branch/slug)\n"
            output+="    Fix manually: edit ${meta_file}\n"
            (( issues++ )) || true
          fi
        done
      fi

      # ── Check 4: Missing .worktrees/ in info/exclude ─────────────────────────
      local exclude_file="${project_root}/.git/info/exclude"
      if ! grep -qxF ".worktrees/" "$exclude_file" 2>/dev/null; then
        output+="  ${RED}✗${RESET} ${BOLD}.worktrees/${RESET} missing from .git/info/exclude\n"
        if confirm "    Add .worktrees/ to info/exclude?"; then
          mkdir -p "${project_root}/.git/info"
          echo ".worktrees/" >> "$exclude_file" \
            && output+="  ${GREEN}✓${RESET} Added .worktrees/ to info/exclude\n" \
            || output+="  ${YELLOW}⚠${RESET} Could not write to info/exclude\n"
        fi
        (( issues++ )) || true
      fi

      # ── Check 5: Missing .wt-meta in info/exclude ───────────────────────────
      if ! grep -qxF ".wt-meta" "$exclude_file" 2>/dev/null; then
        output+="  ${RED}✗${RESET} ${BOLD}.wt-meta${RESET} missing from .git/info/exclude\n"
        if confirm "    Add .wt-meta to info/exclude?"; then
          mkdir -p "${project_root}/.git/info"
          echo ".wt-meta" >> "$exclude_file" \
            && output+="  ${GREEN}✓${RESET} Added .wt-meta to info/exclude\n" \
            || output+="  ${YELLOW}⚠${RESET} Could not write to info/exclude\n"
        fi
        (( issues++ )) || true
      fi

      # ── Check 6: Stale git worktree registrations ────────────────────────────
      local stale_wts=()
      while IFS= read -r line <&5; do
        if [[ "$line" == worktree\ * ]]; then
          local wt_path="${line#worktree }"
          [[ "$wt_path" == "$project_root" ]] && continue
          [[ ! -d "$wt_path" ]] && stale_wts+=("$wt_path")
        fi
      done 5< <(git -C "$project_root" worktree list --porcelain 2>/dev/null)

      if (( ${#stale_wts[@]} > 0 )); then
        output+="  ${RED}✗${RESET} ${#stale_wts[@]} stale git worktree registration(s) (dir removed without pruning)\n"
        for sp in "${stale_wts[@]}"; do
          output+="    ${sp}\n"
        done
        if confirm "    Run 'git worktree prune' and delete stale wt/* branches?"; then
          git -C "$project_root" worktree prune >&2
          for sp in "${stale_wts[@]}"; do
            local stale_slug
            stale_slug=$(basename "$sp")
            git -C "$project_root" branch -D "wt/${stale_slug}" >&2 2>/dev/null || true
          done
          output+="  ${GREEN}✓${RESET} Pruned stale registrations\n"
        fi
        (( issues++ )) || true
      fi

      # ── Print section ────────────────────────────────────────────────────────
      if (( issues > 0 )) || [[ "$any_project" -eq 0 ]]; then
        echo -e "\n${BOLD}${CYAN}wt doctor — ${project_name}${RESET}"
        if (( issues == 0 )); then
          echo -e "  ${GREEN}✓${RESET} all good"
        else
          echo -en "$output"
        fi
        any_project=1
      fi
      (( total_issues += issues )) || true

    done 4< <(find "$base" -maxdepth 1 -mindepth 1 -type d 2>/dev/null)
  done

  if (( any_project == 0 )); then
    info "No projects found in ${PROJECT_SEARCH_PATHS[*]}"
    return 0
  fi

  echo ""
  if (( total_issues == 0 )); then
    success "All projects healthy."
  else
    warn "${total_issues} issue(s) found."
  fi
}

# ─── Entry Point ─────────────────────────────────────────────────────────────

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    new)            cmd_new "$@" ;;
    finish|done)    cmd_finish "$@" ;;
    sync)           cmd_sync "$@" ;;
    drop)           cmd_drop "$@" ;;
    list|ls)        cmd_list "$@" ;;
    doctor)         cmd_doctor "$@" ;;
    help|-h|--help) cmd_help ;;
    *)              error "Unknown command: '$cmd'. Run 'wt help' for usage." ;;
  esac
}

main "$@"
